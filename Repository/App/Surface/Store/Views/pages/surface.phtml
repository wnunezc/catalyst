<main class="store-surface catalyst-demo-surface" data-public-route="store">
    <section class="store-surface__hero">
        <div class="store-surface__copy catalyst-demo-hero__copy">
            <div class="store-surface__tags">
                <span class="catalyst-demo-eyebrow">{{ page.eyebrow }}</span>
                <span class="catalyst-demo-badge">{{ page.badge }}</span>
            </div>
            <h1>{{ page.headline }}</h1>
            <p class="catalyst-demo-lead">{{ page.lead }}</p>
            <div class="store-surface__categories" aria-label="{{ page.productsTitle }}">
                {{#each page.categories}}
                <span>{{ this }}</span>
                {{/each}}
            </div>
            <div class="catalyst-demo-actions">
                <a class="btn btn-primary btn-lg" href="{{ page.primaryCta.href }}">{{ page.primaryCta.label }}</a>
                <a class="btn btn-outline-primary btn-lg" href="{{ page.secondaryCta.href }}">{{ page.secondaryCta.label }}</a>
            </div>
        </div>

        <aside class="store-surface__cart catalyst-demo-card">
            <div class="store-surface__cart-header">
                <span class="catalyst-demo-eyebrow">{{ page.cartTitle }}</span>
                <span class="store-surface__cart-count">{{ page.cartItemCount }}</span>
            </div>
            <div class="store-surface__cart-lines">
                {{#each page.cartLines}}
                <div>
                    <span>{{ name }}</span>
                    <strong>{{ price }}</strong>
                </div>
                {{/each}}
            </div>
            <div class="store-surface__cart-total">
                <span>{{ page.cartSubtotalLabel }}</span>
                <strong>{{ page.cartSubtotal }}</strong>
            </div>
            <button type="button" class="btn btn-primary w-100">{{ page.checkoutLabel }}</button>
        </aside>
    </section>

    <section id="catalog" class="store-surface__catalog catalyst-demo-card" aria-label="{{ page.productsTitle }}">
        <div class="store-surface__catalog-header">
            <div>
                <span class="catalyst-demo-eyebrow">{{ page.productsTitle }}</span>
                <p>{{ page.note }}</p>
            </div>
            <div class="store-surface__search" aria-hidden="true">
                <i class="ti ti-search"></i>
                <span>{{ page.searchLabel }}</span>
            </div>
        </div>
        <div class="store-surface__product-grid">
            {{#each page.products}}
            <article class="store-surface__product-card">
                <div class="store-surface__product-visual" aria-hidden="true">
                    <span>{{ badge }}</span>
                </div>
                <div class="store-surface__product-body">
                    <p class="store-surface__product-type">{{ type }}</p>
                    <h2>{{ name }}</h2>
                    <p>{{ body }}</p>
                </div>
                <div class="store-surface__product-footer">
                    <strong>{{ price }}</strong>
                    <button type="button" class="btn btn-sm btn-outline-primary">{{ page.addLabel }}</button>
                </div>
            </article>
            {{/each}}
        </div>
    </section>
</main>
