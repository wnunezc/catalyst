<main class="account-guest-gateway" data-account-guest="true">
    <section class="account-guest-gateway__card">
        <span class="account-eyebrow">{{ t:dashboard.guest.eyebrow }}</span>
        <h1>{{ t:dashboard.guest.title }}</h1>
        <p>{{ t:dashboard.guest.lead }}</p>
        <div class="account-guest-gateway__actions">
            <a href="/login" class="btn btn-primary">
                <i class="ti ti-login-2 me-1"></i>
                {{ t:dashboard.guest.login }}
            </a>
            <a href="/register" class="btn btn-outline-secondary">
                <i class="ti ti-user-plus me-1"></i>
                {{ t:dashboard.guest.register }}
            </a>
        </div>
        <p class="account-guest-gateway__hint">{{ t:dashboard.guest.hint }}</p>
    </section>
</main>
