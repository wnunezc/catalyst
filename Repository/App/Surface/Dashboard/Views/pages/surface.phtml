<main class="d-grid gap-3" data-public-route="dashboard">
    <section class="row g-3">
        <div class="col-12 col-lg-8">
            <div class="card h-100">
                <div class="card-body p-lg-5">
                    <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
                        <span class="text-primary text-uppercase small fw-bold">{{ page.eyebrow }}</span>
                        <span class="badge text-bg-primary">{{ page.badge }}</span>
                    </div>
                    <h1 class="display-4">{{ page.headline }}</h1>
                    <p class="lead text-muted mb-0">{{ page.lead }}</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <aside class="card h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <span class="text-muted">{{ page.periodLabel }}</span>
                    <strong class="display-6">Q2 · 2026</strong>
                </div>
            </aside>
        </div>
    </section>

    <section class="row g-3" aria-label="{{ page.modulesTitle }}">
        {{#each page.metrics}}
        <div class="col-12 col-md-6 col-xl-3">
            <article class="card h-100">
                <div class="card-body">
                    <span class="text-muted">{{ label }}</span>
                    <strong class="d-block fs-3">{{ value }}</strong>
                    <small>{{ delta }}</small>
                </div>
            </article>
        </div>
        {{/each}}
    </section>

    <section class="row g-3">
        <div class="col-12 col-xl-8">
            <article class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between gap-2">
                    <h2 class="card-title mb-0">{{ page.pipelineTitle }}</h2>
                    <span class="badge text-bg-primary">{{ page.pipelineBadge }}</span>
                </div>
                <div class="card-body d-grid gap-3">
                    {{#each page.pipeline}}
                    <div>
                        <div class="d-flex align-items-center justify-content-between gap-2 mb-1">
                            <span>{{ label }}</span>
                            <strong>{{ value }}</strong>
                        </div>
                        <div class="progress" role="progressbar"><div class="progress-bar {{ barClass }}"></div></div>
                    </div>
                    {{/each}}
                </div>
            </article>
        </div>

        <div class="col-12 col-xl-4">
            <article class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between gap-2">
                    <h2 class="card-title mb-0">{{ page.activityTitle }}</h2>
                    <span class="badge text-bg-primary">{{ page.activityBadge }}</span>
                </div>
                <div class="list-group list-group-flush">
                    {{#each page.activity}}
                    <div class="list-group-item">
                        <span class="text-muted small">{{ time }}</span>
                        <p class="mb-0">{{ event }}</p>
                    </div>
                    {{/each}}
                </div>
            </article>
        </div>
    </section>

    <section class="row g-3" aria-label="{{ page.modulesTitle }}">
        {{#each page.modules}}
        <div class="col-12 col-lg-4">
            <article class="card h-100">
                <div class="card-body">
                    <span class="badge text-bg-light border mb-2">{{ status }}</span>
                    <h2 class="card-title">{{ title }}</h2>
                    <p class="card-text">{{ body }}</p>
                </div>
            </article>
        </div>
        {{/each}}
    </section>
</main>
