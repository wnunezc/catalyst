<div class="account-page" data-account-page="recovery">
    <div class="account-page-header">
        <div>
            <span class="account-eyebrow">{{ t:account.recovery.eyebrow }}</span>
            <h1>{{ t:account.recovery.title }}</h1>
            <p>{{ t:account.recovery.lead }}</p>
        </div>
    </div>

    <section class="row g-3">
        <div class="col-12 col-lg-4">
            <article class="card account-card h-100">
                <div class="card-body">
                    <div class="account-card__icon"><i class="ti ti-key"></i></div>
                    <h2>{{ t:account.recovery.password_title }}</h2>
                    <p>{{ t:account.recovery.password_body }}</p>
                </div>
            </article>
        </div>
        <div class="col-12 col-lg-4">
            <article class="card account-card h-100">
                <div class="card-body">
                    <div class="account-card__icon"><i class="ti ti-2fa"></i></div>
                    <h2>{{ t:account.recovery.mfa_title }}</h2>
                    <p>{{ t:account.recovery.mfa_body }}</p>
                </div>
            </article>
        </div>
        <div class="col-12 col-lg-4">
            <article class="card account-card h-100">
                <div class="card-body">
                    <div class="account-card__icon"><i class="ti ti-headset"></i></div>
                    <h2>{{ t:account.recovery.support_title }}</h2>
                    <p>{{ t:account.recovery.support_body }}</p>
                </div>
            </article>
        </div>
    </section>
</div>
