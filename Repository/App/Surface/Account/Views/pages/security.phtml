<div class="account-page" data-account-page="security">
    {{> "components._page-header" }}

    <section class="row g-3">
        {{#each account_security.cards}}
        <div class="col-12 col-lg-4">
            <article class="card account-card account-card--action h-100">
                <div class="card-body">
                    <div class="account-card__icon"><i class="{{ icon }}"></i></div>
                    <h2>{{ title }}</h2>
                    <p>{{ body }}</p>
                    <a href="{{ href }}" class="btn btn-outline-primary btn-sm">{{ action }}</a>
                </div>
            </article>
        </div>
        {{/each}}
    </section>
</div>
