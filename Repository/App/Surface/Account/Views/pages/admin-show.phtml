<div class="container-fluid py-3" data-account-admin="recovery-show">
    <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
        <div>
            <span class="text-uppercase text-muted fw-semibold small">{{ t:account.admin.show.eyebrow }}</span>
            <h1 class="h3 mb-1">{{ t:account.admin.show.title }} #{{ recovery_request.id }}</h1>
            <p class="text-muted mb-0">{{ t:account.admin.show.description }}</p>
        </div>
        <a href="/admin/account-recovery" class="btn btn-outline-secondary btn-sm">{{ t:account.admin.show.back }}</a>
    </div>

    <div class="row g-3">
        <div class="col-12 col-xl-8">
            <div class="card h-100">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">{{ t:account.admin.index.columns.type }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.request_type_label }}</dd>
                        <dt class="col-sm-4">{{ t:account.admin.index.columns.status }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.status_label }}</dd>
                        <dt class="col-sm-4">{{ t:account.forms.known_email }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.known_email }}</dd>
                        <dt class="col-sm-4">{{ t:account.forms.alternate_email }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.alternate_email }}</dd>
                        <dt class="col-sm-4">{{ t:account.admin.index.columns.created }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.created_at }}</dd>
                        <dt class="col-sm-4">{{ t:account.admin.show.reviewed_at }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.reviewed_at }}</dd>
                        <dt class="col-sm-4">{{ t:account.forms.message }}</dt>
                        <dd class="col-sm-8 text-break">{{ recovery_request.message }}</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-4">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5">{{ t:account.admin.show.review_title }}</h2>
                    <p class="text-muted">{{ t:account.admin.show.review_hint }}</p>
                    {{#if recovery_request.can_review}}
                    <div class="d-grid gap-2">
                        <form method="POST" action="/admin/account-recovery/{{ recovery_request.id }}/approve" data-catalyst="form">
                            {{{ csrf_field }}}
                            <button type="submit" class="btn btn-success w-100">{{ t:account.admin.show.approve }}</button>
                        </form>
                        <form method="POST" action="/admin/account-recovery/{{ recovery_request.id }}/reject" data-catalyst="form">
                            {{{ csrf_field }}}
                            <button type="submit" class="btn btn-outline-danger w-100">{{ t:account.admin.show.reject }}</button>
                        </form>
                    </div>
                    {{else}}
                    <div class="alert alert-info mb-0">{{ t:account.admin.show.already_reviewed }}</div>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
</div>
