<main class="d-grid gap-3" data-public-route="landing">
    <section class="row g-3">
        <div class="col-12 col-lg-7">
            <div class="card h-100">
                <div class="card-body p-lg-5">
                    <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
                        <span class="text-primary text-uppercase small fw-bold">{{ page.eyebrow }}</span>
                        <span class="badge text-bg-primary">{{ page.badge }}</span>
                    </div>
                    <h1 class="display-4">{{ page.headline }}</h1>
                    <p class="lead text-muted">{{ page.lead }}</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary btn-lg" href="{{ page.primaryCta.href }}">{{ page.primaryCta.label }}</a>
                        <a class="btn btn-outline-primary btn-lg" href="{{ page.secondaryCta.href }}">{{ page.secondaryCta.label }}</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-5">
            <aside class="card h-100">
                <div class="card-header"><h2 class="card-title mb-0">{{ page.proofTitle }}</h2></div>
                <div class="card-body d-grid gap-2">
                    {{#each page.proof}}
                    <article class="border rounded p-3">
                        <strong class="d-block text-primary font-monospace fs-4">{{ value }}</strong>
                        <span class="text-muted">{{ label }}</span>
                    </article>
                    {{/each}}
                </div>
            </aside>
        </div>
    </section>

    <section aria-label="{{ page.benefitsTitle }}">
        <div class="mb-3">
            <span class="text-primary text-uppercase small fw-bold">{{ page.benefitsTitle }}</span>
            <h2>{{ page.closingTitle }}</h2>
            <p class="text-muted">{{ page.closingBody }}</p>
        </div>
        <div class="row g-3">
            {{#each page.benefits}}
            <div class="col-12 col-lg-4">
                <article class="card h-100">
                    <div class="card-body">
                        <h3 class="card-title">{{ title }}</h3>
                        <p class="card-text">{{ body }}</p>
                    </div>
                </article>
            </div>
            {{/each}}
        </div>
    </section>

    <section class="card" aria-label="{{ page.stepsTitle }}">
        <div class="card-header"><h2 class="card-title mb-0">{{ page.stepsTitle }}</h2></div>
        <div class="card-body">
            <div class="row g-3">
                {{#each page.steps}}
                <div class="col-12 col-lg-4">
                    <article class="border rounded p-3 h-100">
                        <span class="badge text-bg-primary">{{ step }}</span>
                        <h3 class="h5 mt-2">{{ title }}</h3>
                        <p class="mb-0">{{ body }}</p>
                    </article>
                </div>
                {{/each}}
            </div>
        </div>
    </section>
</main>
