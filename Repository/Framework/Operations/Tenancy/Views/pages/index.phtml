<div class="surface-page surface-page-shell operations-page">
    {{> "components._page-header" }}

    <div class="row g-3">
        <div class="col-xl-6">
            <section class="card border-0 h-100">
                <div class="card-header"><h2 class="h5 mb-0">{{ t:operations.tenancy.runtime.title }}</h2></div>
                <div class="card-body">
                    <dl class="operations-definition-list">
                        <div><dt>{{ t:operations.tenancy.fields.strategy }}</dt><dd><code>{{ runtime.strategy }}</code></dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.target_strategy }}</dt><dd><code>{{ runtime.target_strategy }}</code></dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.resolution_mode }}</dt><dd>{{ runtime.resolution_mode }}</dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.isolation }}</dt><dd>{{ runtime.isolation_label }}</dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.tenant_count }}</dt><dd>{{ runtime.tenant_count }}</dd></div>
                    </dl>
                </div>
            </section>
        </div>
        <div class="col-xl-6">
            <section class="card border-0 h-100">
                <div class="card-header"><h2 class="h5 mb-0">{{ t:operations.tenancy.resolution.title }}</h2></div>
                <div class="card-body">
                    <dl class="operations-definition-list">
                        <div><dt>{{ t:operations.tenancy.fields.status }}</dt><dd>{{ resolution.status_label }}</dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.tenant_key }}</dt><dd><code>{{ resolution.tenant_key }}</code></dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.tenant_id }}</dt><dd>{{ resolution.tenant_id }}</dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.resolved_from }}</dt><dd>{{ resolution.resolved_from }}</dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.baseline_status }}</dt><dd>{{ resolution.baseline_status }}</dd></div>
                    </dl>
                </div>
            </section>
        </div>
    </div>
</div>
