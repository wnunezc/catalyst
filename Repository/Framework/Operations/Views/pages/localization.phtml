<div class="admin-surface admin-surface-shell operations-page operations-admin-page">
    {{> "components._admin-page-header" }}

    <div class="operations-cards operations-cards--wide">
        {{#each locale_cards}}
            <a href="{{ href }}" class="operations-locale-card{{#if is_active}} is-active{{/if }}">
                <span class="operations-card__eyebrow">{{ locale }}</span>
                <strong>{{ label }}</strong>
                <span class="small text-muted">{{ coverage_percent }}% {{ t:ui.labels.coverage }}</span>
                <span class="small text-muted">{{ missing_summary }}</span>
            </a>
        {{/each}}
    </div>

    <section class="card border-0 shadow-sm">
        <div class="card-header">
            <h2 class="h5 mb-1">{{ t:operations.localization.runtime_policy.title }}</h2>
            <p class="text-muted mb-0">{{ t:operations.localization.runtime_policy.description }}</p>
        </div>
        <div class="card-body">
            <form method="POST" action="/workspaces/locale-tools/settings" data-catalyst="form" class="row g-3">
                {{{ csrfField }}}
                <div class="col-md-3">
                    <label for="default_locale" class="form-label">{{ t:operations.localization.runtime_policy.default_locale }}</label>
                    <select id="default_locale" name="default_locale" class="form-select">
                        {{#each default_locale_options}}
                            <option value="{{ value }}"{{#if selected}} selected{{/if}}>
                                {{ label }}
                            </option>
                        {{/each}}
                    </select>
                </div>
                <div class="col-md-9">
                    <label for="locale_labels_json" class="form-label">{{ t:operations.localization.runtime_policy.locale_labels_json }}</label>
                    <textarea id="locale_labels_json" name="locale_labels_json" rows="5" class="form-control" spellcheck="false">{{ locale_labels_json }}</textarea>
                </div>
                <div class="col-12 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary">{{ t:operations.localization.runtime_policy.save }}</button>
                </div>
            </form>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-xl-5">
            <section class="card border-0 shadow-sm h-100">
                <div class="card-header">
                    <h2 class="h5 mb-1">{{ t:operations.localization.create_locale.title }}</h2>
                    <p class="text-muted mb-0">{{ t:operations.localization.create_locale.description }}</p>
                </div>
                <div class="card-body">
                    <form method="POST" action="/workspaces/locale-tools/create-locale" data-catalyst="form" class="row g-3">
                        {{{ csrfField }}}
                        <div class="col-md-4">
                            <label for="locale_code" class="form-label">{{ t:operations.localization.create_locale.locale_code }}</label>
                            <input id="locale_code" type="text" class="form-control" name="locale_code" placeholder="{{ t:operations.localization.create_locale.locale_code_placeholder }}">
                        </div>
                        <div class="col-md-8">
                            <label for="locale_label" class="form-label">{{ t:ui.labels.label }}</label>
                            <input id="locale_label" type="text" class="form-control" name="locale_label" placeholder="{{ t:operations.localization.create_locale.locale_label_placeholder }}">
                        </div>
                        <div class="col-12">
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" name="dry_run" value="1">
                                <span class="form-check-label">{{ t:operations.localization.create_locale.preview_only }}</span>
                            </label>
                        </div>
                        <div class="col-12 d-flex gap-2 flex-wrap">
                            <button type="submit" class="btn btn-outline-primary">{{ t:operations.localization.create_locale.initialize }}</button>
                        </div>
                    </form>
                </div>
            </section>
        </div>

        <div class="col-xl-7">
            <section class="card border-0 shadow-sm h-100">
                <div class="card-header">
                    <h2 class="h5 mb-1">{{ t:operations.localization.sync_locale.title }}</h2>
                    <p class="text-muted mb-0">{{ t:operations.localization.sync_locale.description }}</p>
                </div>
                <div class="card-body">
                    <form method="POST" action="/workspaces/locale-tools/sync-locale" data-catalyst="form" class="row g-3">
                        {{{ csrfField }}}
                        <div class="col-md-5">
                            <label for="target_locale" class="form-label">{{ t:operations.localization.sync_locale.target_locale }}</label>
                            <select id="target_locale" name="target_locale" class="form-select">
                                {{#each sync_locale_options}}
                                    <option value="{{ value }}"{{#if selected}} selected{{/if}}>
                                        {{ label }}
                                    </option>
                                {{/each}}
                            </select>
                        </div>
                        <div class="col-md-7 d-flex align-items-end">
                            <label class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="dry_run_sync" value="1">
                                <span class="form-check-label">{{ t:operations.localization.sync_locale.preview_only }}</span>
                            </label>
                        </div>
                        <div class="col-12 d-flex gap-2 flex-wrap">
                            <button type="submit" class="btn btn-outline-primary">{{ t:operations.localization.sync_locale.sync }}</button>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </div>

    <section class="card border-0 shadow-sm">
        <div class="card-header d-flex flex-column flex-lg-row justify-content-between gap-2">
            <div>
                <h2 class="h5 mb-1">{{ coverage_report_title }}</h2>
                <p class="text-muted mb-0">{{ t:operations.localization.coverage_report.base_locale }}: <code>{{ selected_report_base_locale }}</code></p>
            </div>
            <div class="operations-locale-summary">
                <span class="badge text-bg-light">{{ selected_summary.coverage_percent }}% {{ t:ui.labels.coverage }}</span>
                <span class="badge text-bg-warning">{{ selected_summary.missing_keys_badge }}</span>
                <span class="badge text-bg-secondary">{{ selected_summary.missing_catalogs_badge }}</span>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0 operations-table">
                    <thead>
                    <tr>
                        <th>{{ t:ui.labels.catalog }}</th>
                        <th>{{ t:ui.labels.scope }}</th>
                        <th>{{ t:ui.labels.coverage }}</th>
                        <th>{{ t:operations.localization.coverage_report.missing_keys_column }}</th>
                        <th>{{ t:ui.labels.extras }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#each selected_catalogs}}
                        <tr>
                            <td>
                                <div class="fw-semibold">{{ catalog_name }}.json</div>
                                <div class="small text-muted">{{ present_label }}</div>
                            </td>
                            <td><code>{{ label }}</code></td>
                            <td>{{ coverage_percent }}%</td>
                            <td>
                                <div>{{ missing_count }}</div>
                                {{#if has_missing_preview}}
                                    <div class="small text-muted">{{ missing_preview }}</div>
                                {{/if}}
                            </td>
                            <td>{{ extra_count }}</td>
                        </tr>
                    {{else}}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">{{ t:operations.localization.coverage_report.empty }}</td>
                        </tr>
                    {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>
