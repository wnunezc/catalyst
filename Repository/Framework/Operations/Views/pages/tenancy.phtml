<div class="admin-surface admin-surface-shell operations-page">
    {{> "components._admin-page-header" }}

    <div class="row g-3">
        <div class="col-xl-6">
            <section class="card border-0 h-100">
                <div class="card-header">
                    <h2 class="h5 mb-1">{{ t:operations.tenancy.runtime.title }}</h2>
                    <p class="text-muted mb-0">{{ t:operations.tenancy.runtime.description }}</p>
                </div>
                <div class="card-body">
                    <dl class="operations-definition-list">
                        <div><dt>{{ t:operations.tenancy.fields.runtime_strategy }}</dt><dd><code>{{ summary.strategy }}</code></dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.target_strategy }}</dt><dd><code>{{ summary.target_strategy }}</code></dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.resolution_mode }}</dt><dd>{{ summary.resolution_mode }}</dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.isolation_active }}</dt><dd>{{ summary.data_isolation_label }}</dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.fallback_tenant }}</dt><dd><code>{{ summary.fallback_tenant }}</code></dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.configured_tenants }}</dt><dd>{{ summary.tenant_count }}</dd></div>
                    </dl>
                </div>
            </section>
        </div>
        <div class="col-xl-6">
            <section class="card border-0 h-100">
                <div class="card-header">
                    <h2 class="h5 mb-1">{{ t:operations.tenancy.resolution.title }}</h2>
                    <p class="text-muted mb-0">{{ t:operations.tenancy.resolution.description }}</p>
                </div>
                <div class="card-body">
                    <dl class="operations-definition-list">
                        <div><dt>{{ t:operations.tenancy.fields.resolved_tenant }}</dt><dd><code>{{ resolution.tenant_key }}</code></dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.tenant_id }}</dt><dd>{{ resolution.tenant_id }}</dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.tenant_label }}</dt><dd>{{ resolution.tenant_label }}</dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.resolved_from }}</dt><dd>{{ resolution.resolved_from }}</dd></div>
                        <div><dt>{{ t:ui.labels.host }}</dt><dd><code>{{ resolution.host }}</code></dd></div>
                        <div><dt>{{ t:operations.tenancy.fields.baseline_status }}</dt><dd>{{ resolution.baseline_status }}</dd></div>
                    </dl>
                </div>
            </section>
        </div>
    </div>

    <section class="card border-0 mt-3">
        <div class="card-header">
            <h2 class="h5 mb-1">{{ t:operations.tenancy.catalog.title }}</h2>
            <p class="text-muted mb-0">{{ t:operations.tenancy.catalog.description }}</p>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>{{ t:operations.tenancy.catalog.columns.tenant }}</th>
                            <th>{{ t:operations.tenancy.catalog.columns.id }}</th>
                            <th>{{ t:operations.tenancy.catalog.columns.hosts }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each tenants}}
                            <tr>
                                <td>
                                    <div class="fw-semibold">{{ tenant_label }}</div>
                                    <div class="small text-muted"><code>{{ tenant_key }}</code></div>
                                </td>
                                <td>{{ tenant_id }}</td>
                                <td class="small">{{ hosts_label }}</td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <section class="card border-0 mt-3">
        <div class="card-header">
            <h2 class="h5 mb-1">{{ t:operations.tenancy.decision_note.title }}</h2>
            <p class="text-muted mb-0">{{ t:operations.tenancy.decision_note.description }}</p>
        </div>
        <div class="card-body">
            <p class="mb-0">{{ summary.decision_note }}</p>
        </div>
    </section>
</div>
