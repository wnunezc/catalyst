<div class="col-12">
    <div class="card h-100">
        <div class="card-header"><i class="fa-solid fa-wpforms me-2"></i>{{ t:devtools.form_events.title }}</div>
        <div class="card-body">
            <p class="text-muted small mb-3">
                {{ t:devtools.form_events.description }}
            </p>

            <form data-catalyst="form" action="/test-features/form-demo" method="POST" class="row g-3">
                <div class="col-12 col-md-4">
                    <label class="form-label text-muted small">{{ t:ui.labels.name }}</label>
                    <input type="text" name="name" class="form-control form-control-sm" placeholder="{{ t:devtools.form_events.placeholders.name }}">
                    <div class="invalid-feedback"></div>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label text-muted small">{{ t:devtools.form_events.labels.email }}</label>
                    <input type="email" name="email" class="form-control form-control-sm" placeholder="{{ t:devtools.form_events.placeholders.email }}">
                    <div class="invalid-feedback"></div>
                </div>
                <div class="col-12 col-md-4 d-flex align-items-end">
                    <div class="btn-group-wrap w-100">
                        <button type="submit" data-event="save" class="btn btn-success btn-sm">
                            <i class="fa-solid fa-floppy-disk me-1"></i>{{ t:ui.actions.save }}
                        </button>
                        <button type="submit" data-event="validate" class="btn btn-warning btn-sm text-dark">
                            <i class="fa-solid fa-triangle-exclamation me-1"></i>{{ t:devtools.form_events.actions.force_errors }}
                        </button>
                        <button type="submit" data-event="refresh" class="btn btn-info btn-sm text-dark">
                            <i class="fa-solid fa-rotate me-1"></i>{{ t:ui.actions.refresh }}
                        </button>
                        <button type="submit" data-event="redirect" class="btn btn-secondary btn-sm">
                            <i class="fa-solid fa-arrow-right me-1"></i>{{ t:ui.actions.redirect }}
                        </button>
                    </div>
                </div>
            </form>

            <div class="mt-3 p-2 rounded bg-body-tertiary border">
                <p class="text-muted small mb-1">{{ t:devtools.form_events.mapping.title }}</p>
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>data-event</th><th>{{ t:devtools.form_events.mapping.php_method }}</th><th>{{ t:devtools.form_events.mapping.behavior }}</th></tr></thead>
                        <tbody>
                            <tr><td><span class="code-badge">save</span></td><td><span class="code-badge">onSave()</span></td><td class="small text-muted">{{ t:devtools.form_events.mapping.rows.save }}</td></tr>
                            <tr><td><span class="code-badge">validate</span></td><td><span class="code-badge">onValidate()</span></td><td class="small text-muted">{{ t:devtools.form_events.mapping.rows.validate }}</td></tr>
                            <tr><td><span class="code-badge">refresh</span></td><td><span class="code-badge">onRefresh()</span></td><td class="small text-muted">{{ t:devtools.form_events.mapping.rows.refresh }}</td></tr>
                            <tr><td><span class="code-badge">redirect</span></td><td><span class="code-badge">onRedirect()</span></td><td class="small text-muted">{{ t:devtools.form_events.mapping.rows.redirect }}</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
