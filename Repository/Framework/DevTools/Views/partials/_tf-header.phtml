<section class="ui-catalog-head card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="ui-catalog-head__row">
            <div class="ui-catalog-head__copy">
                <div class="ui-catalog-head__eyebrow">{{ t:devtools.harness.eyebrow }}</div>
                <h1 class="ui-catalog-head__title">{{ title }}</h1>
                <p class="ui-catalog-head__lede mb-0">
                    {{ t:devtools.harness.description }}
                </p>
            </div>

            <div class="ui-catalog-head__actions">
                <button type="button" class="btn btn-sm btn-primary" data-catalyst-href="/test-features/ui-showcase">
                    <i class="ti ti-layout-dashboard me-1"></i>{{ t:devtools.harness.actions.ui_showcase }}
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-catalyst-href="/workspaces/module-designer">
                    <i class="ti ti-package-import me-1"></i>{{ t:devtools.harness.actions.module_designer }}
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-catalyst-href="/operations">
                    <i class="ti ti-adjustments-horizontal me-1"></i>{{ t:devtools.harness.actions.operations }}
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-catalyst-href="/users/roles">
                    <i class="ti ti-shield-lock me-1"></i>{{ t:devtools.harness.actions.roles }}
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-catalyst-href="/users/permissions">
                    <i class="ti ti-key me-1"></i>{{ t:devtools.harness.actions.permissions }}
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger" data-catalyst-href="/test-features/flash/clear">
                    <i class="ti ti-trash me-1"></i>{{ t:devtools.harness.actions.clear_flash }}
                </button>
            </div>
        </div>

        <div class="ui-catalog-head__chips">
            <span class="ui-chip">{{ t:devtools.harness.chips.dev_only }}</span>
            <span class="ui-chip">{{ t:devtools.harness.chips.runtime_probes }}</span>
            <span class="ui-chip">{{ t:devtools.harness.chips.no_product_content }}</span>
            <span class="ui-chip">{{ t:devtools.harness.chips.operational_diagnostics }}</span>
        </div>
    </div>
</section>
