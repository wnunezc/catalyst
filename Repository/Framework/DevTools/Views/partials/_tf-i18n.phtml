<div class="col-12">
    <div class="card h-100">
        <div class="card-header"><i class="fa-solid fa-language me-2"></i>{{ t:devtools.i18n_demo.title }}</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <p class="text-muted small mb-2">
                        {{ t:devtools.i18n_demo.active_locale }}: <span class="code-badge">{{ locale }}</span>
                        &nbsp;{{ t:devtools.i18n_demo.default_locale }}: <span class="code-badge">{{ default_locale }}</span>
                    </p>
                    <form method="POST" action="/test-features/i18n/set-locale" data-catalyst="form" class="btn-group-wrap">
                        {{{ set_locale_csrf_field }}}
                        <button class="btn btn-outline-info btn-sm" type="submit" name="locale" value="en">{{ t:ui.languages.en }} (en)</button>
                        <button class="btn btn-outline-warning btn-sm" type="submit" name="locale" value="es">Español (es)</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-catalyst-href="/test-features/i18n" data-catalyst-target="_blank">
                            <i class="fa-solid fa-arrow-up-right-from-square me-1"></i>{{ t:devtools.i18n_demo.raw_json }}
                        </button>
                    </form>
                </div>

                <div class="col-12 col-md-8">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead><tr><th>{{ t:devtools.i18n_demo.columns.example }}</th><th>{{ t:devtools.i18n_demo.columns.result }}</th></tr></thead>
                            <tbody>
                                {{#each validation_examples}}
                                <tr>
                                    <td><span class="code-badge">{{ this.label }}</span></td>
                                    <td class="{{ this.row_class }} small">{{ this.result }}</td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <p class="text-muted small mb-2 fw-semibold">{{ t:devtools.i18n_demo.date_formatting }} - <span class="code-badge">format_date()</span></p>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead><tr><th>{{ t:devtools.i18n_demo.columns.format }}</th><th>{{ t:devtools.i18n_demo.columns.output }}</th></tr></thead>
                            <tbody>
                                {{#each date_rows}}
                                <tr><td><span class="code-badge">{{ this.format }}</span></td><td>{{ this.output }}</td></tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <p class="text-muted small mb-2 fw-semibold">{{ t:devtools.i18n_demo.select_options }} - <span class="code-badge">getList()</span></p>
                    <div class="mb-2">
                        <label class="form-label text-muted small">{{ gender_options_label }}</label>
                        <select class="form-select form-select-sm">
                            {{#each gender_options}}
                            <option value="{{ this.value }}"{{#if this.selected}} selected{{/if}}>{{ this.label }}</option>
                            {{/each}}
                        </select>
                    </div>
                    <div>
                        <label class="form-label text-muted small">{{ status_options_label }}</label>
                        <select class="form-select form-select-sm">
                            {{#each status_options}}
                            <option value="{{ this.value }}"{{#if this.selected}} selected{{/if}}>{{ this.label }}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
