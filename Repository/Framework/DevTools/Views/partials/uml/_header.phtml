<section class="ui-catalog-head card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="ui-catalog-head__row">
            <div class="ui-catalog-head__copy">
                <div class="ui-catalog-head__eyebrow">{{ t:uml.eyebrow }}</div>
                <h1 class="ui-catalog-head__title">{{ title }}</h1>
                <p class="ui-catalog-head__lede mb-0">
                    {{ t:uml.description }}
                </p>
            </div>

            <div class="ui-catalog-head__actions">
                <button type="button" class="btn btn-sm btn-primary" data-catalyst-href="/test-features">
                    <i class="ti ti-flask me-1"></i>{{ t:devtools.module.devtools_label }}
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-catalyst-href="/test-features/ui-showcase">
                    <i class="ti ti-components me-1"></i>{{ t:devtools.module.ui_showcase_label }}
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-catalyst-href="/test-layout">
                    <i class="ti ti-layout me-1"></i>{{ t:devtools.module.layout_smoke_label }}
                </button>
            </div>
        </div>

        <div class="ui-catalog-head__chips">
            <span class="ui-chip">{{ chip_environment }}</span>
            <span class="ui-chip">{{ chip_configured }}</span>
            <span class="ui-chip">{{ chip_loaded_sections }}</span>
        </div>
    </div>
</section>
