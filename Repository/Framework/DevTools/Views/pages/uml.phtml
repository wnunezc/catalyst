<div class="uml-showcase">
    {{> "components._page-header" }}

    <div class="row g-3">
        <div class="col-12 col-xl-9">
            <section class="card uml-shell">
                <div class="card-header">
                    <div class="ui-section-head">
                        <div>
                            <h2 class="ui-section-title mb-1">{{ t:uml.shell.title }}</h2>
                            <p class="ui-section-subtitle mb-0">
                                {{ t:uml.shell.description }}
                            </p>
                        </div>
                        <div class="ui-section-kicker">{{ t:uml.shell.kicker }}</div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <nav class="nav nav-tabs px-3 pt-3" role="tablist" aria-label="{{ t:uml.shell.aria_label }}">
                        {{#each uml_tabs}}
                        <button
                            id="{{ this.button_id }}"
                            class="nav-link{{#if this.active}} active{{/if}}"
                            type="button"
                            data-bs-toggle="tab"
                            data-bs-target="#{{ this.panel_id }}"
                            role="tab"
                            aria-selected="{{ this.aria_selected }}"
                            aria-controls="{{ this.panel_id }}"
                        >{{ this.label }}</button>
                        {{/each}}
                    </nav>
                    {{> "../partials/uml/_tab-panels" }}
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-3">
            {{> "../partials/uml/_rail" }}
        </div>
    </div>
</div>
