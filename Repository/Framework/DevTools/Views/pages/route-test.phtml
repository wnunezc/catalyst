<div class="container py-5 text-center">
    <h1 class="display-4 fw-bold text-primary mb-2">{{ title }}</h1>
    <p class="text-secondary mb-4">
        {{ version_line }}
    </p>

    <div class="card d-inline-block shadow-sm mb-4">
        <div class="card-body px-5 py-4">
            <i class="fa-solid fa-circle-check text-success fs-4 me-2"></i>
            <span class="fs-5">{{ t:devtools.route_test.router_ok }}</span>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-3 justify-content-center">
        <button type="button" class="btn btn-primary btn-lg" data-catalyst-href="/configuration/environment-setup">
            <i class="fa-solid fa-gear me-2"></i>{{ t:settings.module.setup_label }}
        </button>
        {{#if show_login}}
        <button type="button" class="btn btn-success btn-lg" data-catalyst-href="/login">
            <i class="fa-solid fa-right-to-bracket me-2"></i>{{ t:auth.login.submit }}
        </button>
        {{/if}}
        <button type="button" class="btn btn-secondary btn-lg" data-catalyst-href="/test-features">
            <i class="fa-solid fa-flask me-2"></i>{{ t:devtools.module.test_features_label }}
        </button>
        <button type="button" class="btn btn-outline-info btn-lg" data-catalyst-href="/uml">
            <i class="fa-solid fa-diagram-project me-2"></i>{{ t:devtools.module.architecture_breadcrumb }}
        </button>
    </div>

    <p class="text-muted mt-4 fst-italic small">
        {{ t:devtools.route_test.footer }}
    </p>
</div>
