<div data-account-page="recovery">
    {{> "components._page-header" }}

    <section class="row g-3">
        <div class="col-12 col-lg-4">
            <article class="card h-100">
                <div class="card-body d-grid gap-3">
                    <div class="d-inline-flex align-items-center justify-content-center rounded bg-primary-subtle text-primary fs-4 p-2"><i class="ti ti-key"></i></div>
                    <h2>{{ t:account.recovery.password_title }}</h2>
                    <p>{{ t:account.recovery.password_body }}</p>
                </div>
            </article>
        </div>
        <div class="col-12 col-lg-4">
            <article class="card h-100">
                <div class="card-body d-grid gap-3">
                    <div class="d-inline-flex align-items-center justify-content-center rounded bg-primary-subtle text-primary fs-4 p-2"><i class="ti ti-2fa"></i></div>
                    <h2>{{ t:account.recovery.mfa_title }}</h2>
                    <p>{{ t:account.recovery.mfa_body }}</p>
                </div>
            </article>
        </div>
        <div class="col-12 col-lg-4">
            <article class="card h-100">
                <div class="card-body d-grid gap-3">
                    <div class="d-inline-flex align-items-center justify-content-center rounded bg-primary-subtle text-primary fs-4 p-2"><i class="ti ti-headset"></i></div>
                    <h2>{{ t:account.recovery.support_title }}</h2>
                    <p>{{ t:account.recovery.support_body }}</p>
                </div>
            </article>
        </div>
    </section>
</div>
