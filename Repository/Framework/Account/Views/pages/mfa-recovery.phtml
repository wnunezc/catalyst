<div data-account-page="mfa-recovery">
    {{> "components._page-header" }}

    <section class="row g-3">
        <div class="col-12 col-xl-7">
            <article class="card h-100">
                <div class="card-body d-grid gap-3">
                    <div class="account-section-title">
                        <div>
                            <h2>{{ t:account.mfa_recovery.form_title }}</h2>
                            <p>{{ t:account.mfa_recovery.form_hint }}</p>
                        </div>
                    </div>
                    <form method="POST" action="/account/recovery/mfa" class="account-form" data-catalyst="form">
                        {{{ csrf_field }}}
                        <div class="mb-3">
                            <label for="email" class="form-label">{{ t:account.forms.email }}</label>
                            <input type="email" class="form-control" id="email" name="email" value="{{ account_user.email }}" autocomplete="email" readonly required>
                        </div>
                        <button type="submit" class="btn btn-primary">{{ t:account.mfa_recovery.submit }}</button>
                    </form>
                </div>
            </article>
        </div>
        <div class="col-12 col-xl-5">
            <article class="card h-100">
                <div class="card-body d-grid gap-3">
                    <div class="alert alert-info mb-0">
                        <i class="ti ti-info-circle"></i>
                        <p>{{ t:account.mfa_recovery.note }}</p>
                    </div>
                    <div class="alert alert-warning mb-0">
                        <i class="ti ti-alert-triangle"></i>
                        <p>{{ t:account.mfa_recovery.warning }}</p>
                    </div>
                </div>
            </article>
        </div>
    </section>
</div>
