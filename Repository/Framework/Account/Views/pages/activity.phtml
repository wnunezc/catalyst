<div class="account-page" data-account-page="activity">
    {{> "components._page-header" }}

    <article class="card account-card">
        <div class="card-body">
            <div class="account-timeline account-timeline--wide">
                {{#each account_activity.events}}
                <div class="account-timeline__item">
                    <span>{{ created_at }}</span>
                    <strong>{{ title }}</strong>
                    <small>{{ body }}</small>
                </div>
                {{/each}}
            </div>
        </div>
    </article>
</div>
