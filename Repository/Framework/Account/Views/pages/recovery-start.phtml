<section class="min-vh-100 d-flex align-items-center justify-content-center py-5" data-account-recovery="start" aria-labelledby="account-recovery-start-title">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-8">
                <section class="card shadow-sm">
                    <div class="card-body d-grid gap-3">
                        <span class="account-eyebrow">{{ t:account.recovery_public.eyebrow }}</span>
                        <h1 id="account-recovery-start-title" class="mb-0">{{ t:account.recovery_public.start_title }}</h1>
                        <p class="mb-0">{{ t:account.recovery_public.start_lead }}</p>
                        <div class="account-recovery-options">
                            <a href="/forgot-password" class="account-recovery-options__item">
                                <i class="ti ti-key" aria-hidden="true"></i>
                                <strong>{{ t:account.recovery_public.forgot_password }}</strong>
                                <span>{{ t:account.recovery_public.forgot_password_hint }}</span>
                            </a>
                            <a href="/account-recovery/mfa" class="account-recovery-options__item">
                                <i class="ti ti-2fa" aria-hidden="true"></i>
                                <strong>{{ t:account.recovery_public.lost_mfa }}</strong>
                                <span>{{ t:account.recovery_public.lost_mfa_hint }}</span>
                            </a>
                            <a href="/account-recovery/support" class="account-recovery-options__item">
                                <i class="ti ti-mail-x" aria-hidden="true"></i>
                                <strong>{{ t:account.recovery_public.lost_email }}</strong>
                                <span>{{ t:account.recovery_public.lost_email_hint }}</span>
                            </a>
                            <a href="/account-recovery/compromised" class="account-recovery-options__item">
                                <i class="ti ti-alert-triangle" aria-hidden="true"></i>
                                <strong>{{ t:account.recovery_public.compromised }}</strong>
                                <span>{{ t:account.recovery_public.compromised_hint }}</span>
                            </a>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>
</section>
