<section class="min-vh-100 d-flex align-items-center justify-content-center py-5" data-account-recovery="mfa" aria-labelledby="account-recovery-mfa-title">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-5">
                <section class="card shadow-sm">
                    <div class="card-body d-grid gap-3">
                        <span class="account-eyebrow">{{ t:account.recovery_public.eyebrow }}</span>
                        <h1 id="account-recovery-mfa-title" class="mb-0">{{ t:account.recovery_public.mfa_title }}</h1>
                        <p class="mb-0">{{ t:account.recovery_public.mfa_lead }}</p>
                        <form method="POST" action="/account-recovery/mfa" class="account-form" data-catalyst="form">
                            {{{ csrf_field }}}
                            <div class="mb-3">
                                <label for="email" class="form-label">{{ t:account.forms.email }}</label>
                                <input type="email" class="form-control" id="email" name="email" autocomplete="email" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">{{ t:account.recovery_public.mfa_submit }}</button>
                        </form>
                        <p class="small text-muted mb-0">{{ t:account.recovery_public.generic_response_hint }}</p>
                    </div>
                </section>
            </div>
        </div>
    </div>
</section>
