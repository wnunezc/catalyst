<div data-account-page="security">
    {{> "components._page-header" }}

    <section class="row g-3">
        {{#each account_security.cards}}
        <div class="col-12 col-lg-4">
            <article class="card h-100">
                <div class="card-body d-grid gap-3">
                    <div class="d-inline-flex align-items-center justify-content-center rounded bg-primary-subtle text-primary fs-4 p-2"><i class="{{ icon }}"></i></div>
                    <h2>{{ title }}</h2>
                    <p>{{ body }}</p>
                    <a href="{{ href }}" class="btn btn-outline-primary btn-sm">{{ action }}</a>
                </div>
            </article>
        </div>
        {{/each}}
    </section>
</div>
