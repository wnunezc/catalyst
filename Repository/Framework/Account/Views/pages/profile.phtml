<div data-account-page="profile">
    {{> "components._page-header" }}

    <section class="row g-3">
        <div class="col-12 col-xl-7">
            <article class="card h-100">
                <div class="card-header">
                    <div>
                        <h2 class="card-title mb-1">{{ t:account.profile.identity_title }}</h2>
                        <p class="text-muted mb-0">{{ t:account.profile.identity_hint }}</p>
                    </div>
                </div>
                <div class="card-body">
                    <dl class="account-definition-list">
                        <div>
                            <dt>{{ t:account.profile.name }}</dt>
                            <dd>{{ account_user.name }}</dd>
                        </div>
                        <div>
                            <dt>{{ t:account.profile.email }}</dt>
                            <dd>{{ account_user.email }}</dd>
                        </div>
                        <div>
                            <dt>{{ t:account.profile.role }}</dt>
                            <dd>{{ account_user.role }}</dd>
                        </div>
                        <div>
                            <dt>{{ t:account.profile.tenant }}</dt>
                            <dd>{{ account_user.tenant_label }}</dd>
                        </div>
                    </dl>
                </div>
            </article>
        </div>
        <div class="col-12 col-xl-5">
            <article class="card h-100">
                <div class="card-header">
                    <div>
                        <h2 class="card-title mb-1">{{ t:account.profile.scope_title }}</h2>
                        <p class="text-muted mb-0">{{ t:account.profile.scope_hint }}</p>
                    </div>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <img src="{{ account_avatar_src }}" alt="{{ t:account.profile.avatar_alt }}" class="rounded-circle border" width="72" height="72">
                        <div>
                            <h3 class="h6 mb-1">{{ t:account.profile.avatar_title }}</h3>
                            <p class="text-muted mb-0">{{ t:account.profile.avatar_hint }}</p>
                        </div>
                    </div>
                    <form method="POST" action="/account/profile/avatar" enctype="multipart/form-data" data-catalyst="form" class="row g-3">
                        {{{ csrfField }}}
                        <div class="col-12">
                            <label class="form-label" for="account-avatar">{{ t:account.profile.avatar_label }}</label>
                            <input id="account-avatar" name="avatar" type="file" class="form-control" accept="image/jpeg,image/png,image/webp" required>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">{{ t:account.profile.avatar_submit }}</button>
                        </div>
                    </form>
                </div>
            </article>
        </div>
    </section>
</div>
