<div class="card auth-card auth-card--lg">
    <div class="card-body">
        <div class="auth-card__header auth-card__header--center">
            <span class="auth-card__icon" aria-hidden="true">
                <i class="fa-solid fa-shield-check"></i>
            </span>
            <span class="auth-card__eyebrow">Authenticator setup</span>
            <h1 class="auth-card__title">{{ title }}</h1>
            <p class="auth-card__subtitle">{{ t:auth.mfa.setup_subtitle }}</p>
        </div>

        {{#if forced_setup}}
        <div class="alert alert-warning d-flex align-items-start gap-2 mb-4">
            <i class="fa-solid fa-triangle-exclamation mt-1 flex-shrink-0"></i>
            <span>{{ t:auth.mfa.setup_forced_notice }}</span>
        </div>
        {{/if}}

        {{#if mfa_active}}
            {{#unless forced_setup}}
            <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
                <i class="fa-solid fa-shield-check flex-shrink-0"></i>
                <span>{{ t:auth.mfa.already_enabled }}</span>
            </div>

            {{#if has_backup_codes}}
            <div class="alert alert-warning mb-4">
                <p class="fw-semibold mb-2">
                    <i class="fa-solid fa-key me-1"></i>
                    {{ t:auth.mfa.backup_codes_title }}
                </p>
                <p class="small mb-2">{{ t:auth.mfa.backup_codes_hint }}</p>
                <div class="d-flex flex-wrap gap-2 font-monospace">
                    {{#each backup_codes}}
                    <span class="badge bg-dark fs-6">{{ this }}</span>
                    {{/each}}
                </div>
                {{#if continue_redirect}}
                <button type="button" class="btn btn-sm btn-primary mt-3" data-catalyst-href="{{ continue_redirect }}">
                    {{ t:auth.mfa.back_home }}
                </button>
                {{/if}}
            </div>
            {{/if}}

            <hr class="my-4">
            <p class="text-muted small mb-3">{{ t:auth.mfa.disable_hint }}</p>
            <form data-catalyst="form" method="POST" action="/mfa/disable" novalidate>
                {{{ csrf_token_field }}}
                <div class="mb-3">
                    <label for="mfa-disable-password" class="form-label">
                        {{ t:auth.mfa.current_password }}
                    </label>
                    <div class="input-group has-validation">
                        <input
                            type="password"
                            id="mfa-disable-password"
                            name="password"
                            class="form-control{{ password_invalid_class }}"
                            required
                            autocomplete="current-password"
                        >
                        <button
                            type="button"
                            class="btn btn-outline-secondary"
                            data-password-toggle
                            tabindex="-1"
                            aria-label="{{ t:auth.common.show_password }}"
                        >
                            <i class="fa-solid fa-eye"></i>
                        </button>
                        <div class="invalid-feedback">{{ password_error }}</div>
                    </div>
                </div>
                <button type="submit" data-event="disable-mfa" class="btn btn-danger w-100">
                    <i class="fa-solid fa-shield-xmark me-1"></i>
                    {{ t:auth.mfa.disable_button }}
                </button>
            </form>
            {{/unless}}
        {{else}}
        <ol class="list-group list-group-numbered mb-4">
            <li class="list-group-item border-0 ps-0">{{ t:auth.mfa.step1 }}</li>
            <li class="list-group-item border-0 ps-0">{{ t:auth.mfa.step2 }}</li>
            <li class="list-group-item border-0 ps-0">{{ t:auth.mfa.step3 }}</li>
        </ol>

        <div class="text-center mb-3">
            <div
                id="mfa-qr"
                class="d-inline-block p-2 bg-white rounded border"
                data-qr-uri="{{ qr_uri }}"
            ></div>
        </div>

        <details class="mb-4">
            <summary class="text-muted small auth-details-summary">
                {{ t:auth.mfa.manual_entry }}
            </summary>
            <div class="mt-2 p-2 bg-body-tertiary rounded font-monospace small text-break">
                {{ secret }}
            </div>
        </details>

        <form data-catalyst="form" method="POST" action="/mfa/enable" novalidate>
            {{{ csrf_token_field }}}
            <div class="mb-3">
                <label for="mfa-code" class="form-label">
                    {{ t:auth.mfa.enter_code }}
                </label>
                <input
                    type="text"
                    id="mfa-code"
                    name="code"
                    class="form-control form-control-lg text-center font-monospace{{ code_invalid_class }}"
                    inputmode="text"
                    pattern="[0-9 -]{6,7}"
                    maxlength="7"
                    placeholder="000000 or 000-000"
                    required
                    autocomplete="one-time-code"
                    autofocus
                >
                <div class="invalid-feedback">{{ code_error }}</div>
                <div class="form-text">{{ t:auth.mfa.code_hint }}</div>
            </div>
            <button type="submit" data-event="enable-mfa" class="btn btn-success w-100">
                <i class="fa-solid fa-shield-check me-1"></i>
                {{ t:auth.mfa.enable_button }}
            </button>
        </form>
        {{/if}}

        {{#unless forced_setup}}
        <div class="auth-link-row">
            <a href="/" class="text-decoration-none">
                &larr; {{ t:auth.mfa.back_home }}
            </a>
        </div>
        {{/unless}}
    </div>
</div>
