<div class="card w-100">
    <div class="card-body">
        <div class="text-center mb-4">
            <span class="small text-uppercase text-primary fw-semibold">Account recovery</span>
            <h1 class="h3 mb-2">{{ title }}</h1>
            <p class="text-muted mb-0">{{ t:auth.forgot_password.subtitle }}</p>
        </div>

        <form data-catalyst="form" method="POST" action="/forgot-password" novalidate>
            {{{ csrf_token_field }}}

            <div class="mb-4">
                <label for="email" class="form-label">
                    {{ t:auth.forgot_password.email }}
                </label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    class="form-control{{ email_invalid_class }}"
                    value="{{ email_value }}"
                    required
                    autocomplete="email"
                    autofocus
                >
                <div class="invalid-feedback">{{ email_error }}</div>
            </div>

            <button type="submit" data-event="send-reset-link" class="btn btn-primary w-100">
                {{ t:auth.forgot_password.submit }}
            </button>
        </form>

        <div class="auth-link-row auth-link-row--stack mb-0">
            <a href="/login" class="text-decoration-none">
                &larr; {{ t:auth.forgot_password.back_to_login }}
            </a>
            <a href="/account-recovery/start" class="text-decoration-none">
                {{ t:auth.forgot_password.advanced_recovery_link }}
            </a>
        </div>
    </div>
</div>
