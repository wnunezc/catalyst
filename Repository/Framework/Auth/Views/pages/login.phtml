<div class="card auth-card auth-card--sm">
    <div class="card-body">
        <div class="auth-card__header auth-card__header--center">
            <span class="auth-card__eyebrow">Account access</span>
            <h1 class="auth-card__title">{{ title }}</h1>
            <p class="auth-card__subtitle">{{ t:auth.login.subtitle }}</p>
        </div>

        <form data-catalyst="form" method="POST" action="/login" novalidate>
            {{{ csrf_token_field }}}
            <input type="hidden" name="redirect" value="{{ redirect_value }}">

            <div class="mb-3">
                <label for="email" class="form-label">
                    {{ t:auth.login.email }}
                </label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    class="form-control{{ email_invalid_class }}"
                    value="{{ email_value }}"
                    required
                    autocomplete="email"
                    autofocus
                >
                <div class="invalid-feedback">{{ email_error }}</div>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label for="password" class="form-label mb-0">
                        {{ t:auth.login.password }}
                    </label>
                    <a href="/forgot-password" class="small text-decoration-none">
                        {{ t:auth.login.forgot }}
                    </a>
                </div>
                <div class="input-group has-validation">
                    <input
                        type="password"
                        id="password"
                        name="password"
                        class="form-control{{ password_invalid_class }}"
                        required
                        autocomplete="current-password"
                    >
                    <button type="button" class="btn btn-outline-secondary" data-password-toggle tabindex="-1" aria-label="{{ t:auth.common.show_password }}">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                    <div class="invalid-feedback">{{ password_error }}</div>
                </div>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="remember" name="remember" value="1"{{ remember_checked_attr }}>
                <label class="form-check-label small" for="remember">
                    {{ t:auth.login.remember }}
                </label>
            </div>

            <button type="submit" data-event="login" class="btn btn-primary w-100">
                {{ t:auth.login.submit }}
            </button>
        </form>

        {{#if has_social_login}}
        {{> "../partials/_auth-social" }}
        {{/if}}

        <div class="auth-link-row auth-link-row--stack mb-0">
            <p class="mb-0">
                {{#if registration_enabled}}
                {{ t:auth.login.no_account }}
                <a href="/register" class="text-decoration-none">
                    {{ t:auth.login.create_account }}
                </a>
                <span class="auth-link-separator" aria-hidden="true">·</span>
                {{/if}}
                <a href="/verify-email" class="text-decoration-none">
                    {{ t:auth.login.verify_email }}
                </a>
            </p>
            <p class="mb-0">
                {{ t:auth.login.recovery_help }}
                <a href="/account-recovery/start" class="text-decoration-none">
                    {{ t:auth.login.recovery_help_link }}
                </a>
            </p>
        </div>
    </div>
</div>
