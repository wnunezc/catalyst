<div class="card w-100">
    <div class="card-body">
        <div class="text-center mb-4">
            <span class="small text-uppercase text-primary fw-semibold">Credential reset</span>
            <h1 class="h3 mb-2">{{ title }}</h1>
            <p class="text-muted mb-0">{{ t:auth.reset_password.subtitle }}</p>
        </div>

        <form data-catalyst="form" method="POST" action="/reset-password/{{ token }}" novalidate data-password-policy="{{ password_policy_json }}">
            {{{ csrf_token_field }}}

            <div class="mb-3">
                <label for="password" class="form-label">
                    {{ t:auth.reset_password.password }}
                </label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    class="form-control{{ password_invalid_class }}"
                    required
                    autocomplete="new-password"
                    minlength="{{ password_policy.minLength }}"
                    data-strength
                    data-password-policy="{{ password_policy_json }}"
                    autofocus
                >
                <div class="invalid-feedback">{{ password_error }}</div>
            </div>

            <div class="mb-4">
                <label for="password_confirm" class="form-label">
                    {{ t:auth.reset_password.password_confirm }}
                </label>
                <input
                    type="password"
                    id="password_confirm"
                    name="password_confirm"
                    class="form-control{{ password_confirm_invalid_class }}"
                    required
                    autocomplete="new-password"
                >
                <div class="invalid-feedback">{{ password_confirm_error }}</div>
            </div>

            <button type="submit" data-event="reset-password" class="btn btn-primary w-100">
                {{ t:auth.reset_password.submit }}
            </button>
        </form>
    </div>
</div>
