<div class="surface-page surface-page-shell surface-content-shell surface-content-shell--xl">
    {{> "components._page-header" }}

    <section class="row g-3 mb-3" aria-label="{{ t:settings.health.title }}">
        {{#each healthMetrics}}
            <div class="col-12 col-sm-6 col-xl">
                <article class="card h-100">
                    <div class="card-body">
                        <span class="small text-muted d-block mb-1">{{ label }}</span>
                        {{#if badge_class}}
                            <span class="badge {{ badge_class }}">{{ value }}</span>
                        {{else}}
                            <strong class="d-block{{#if value_class}} {{ value_class }}{{/if}}">{{ value }}</strong>
                        {{/if}}
                    </div>
                </article>
            </div>
        {{/each}}
    </section>

    <section class="card mb-3">
        <div class="card-header">
            <div>
                <h2 class="card-title">{{ t:settings.health.endpoints.title }}</h2>
                <p class="small text-muted mb-0">{{ t:settings.health.endpoints.description }}</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-catalyst-href="/configuration/application-health/live"
                        data-catalyst-target="_blank">{{ t:settings.health.endpoints.live }}</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-catalyst-href="/configuration/application-health/ready"
                        data-catalyst-target="_blank">{{ t:settings.health.endpoints.ready }}</button>
            </div>
        </div>
    </section>

    <section class="card mb-3">
        <div class="card-header">
            <div>
                <h2 class="card-title">{{ t:settings.health.route_contract.title }}</h2>
                <p class="small text-muted mb-0">{{ t:settings.health.route_contract.no_issues }}</p>
            </div>
            <span class="badge {{ routeContract.badge_class }}">{{ routeContract.badge_label }}</span>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                {{#each routeContract.checks}}
                    <div class="col-12 col-md-6 col-xl">
                        <div class="border rounded p-3 h-100">
                            <strong class="d-block mb-2">{{ label }}</strong>
                            <div class="d-flex justify-content-between align-items-center gap-2">
                                <span class="small text-muted">{{ checked_label }}</span>
                                <span class="badge {{ badge_class }}">{{ badge_label }}</span>
                            </div>
                        </div>
                    </div>
                {{/each}}
            </div>

            {{#if routeContract.issues}}
                <div class="list-group list-group-flush border rounded">
                    {{#each routeContract.issues}}
                        <div class="list-group-item py-2 small">
                            <strong>{{ type_label }}:</strong>
                            {{ message }}
                        </div>
                    {{/each}}
                </div>
            {{else}}
                <p class="mb-0 text-muted small">{{ t:settings.health.route_contract.no_issues }}</p>
            {{/if}}
        </div>
    </section>

    <div class="row g-3">
        {{#each sectionsView}}
            <div class="col-xl-6">
                <section class="card h-100">
                    <div class="card-header">
                        <h2 class="card-title">{{ label }}</h2>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle mb-0">
                                <thead class="thead-sm text-uppercase fs-xxs">
                                <tr>
                                    <th>{{ t:settings.health.table.check }}</th>
                                    <th>{{ t:settings.health.table.status }}</th>
                                    <th>{{ t:settings.health.table.detail }}</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#each checks}}
                                    <tr>
                                        <td class="fw-semibold">{{ label }}</td>
                                        <td><span class="badge {{ badge_class }}">{{ status_label }}</span></td>
                                        <td class="text-muted small">{{ detail }}</td>
                                    </tr>
                                {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>
            </div>
        {{/each}}
    </div>
</div>
