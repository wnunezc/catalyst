<div class="surface-page surface-page-shell">
    {{> "components._page-header" }}

    <section class="card border-0 mb-3">
        <div class="card-header">
            <h2 class="h5 mb-1">{{ t:settings.feature_flags.catalog.title }}</h2>
            <p class="text-muted mb-0">{{ t:settings.feature_flags.catalog.description }}</p>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                    <tr>
                        <th>{{ t:settings.feature_flags.catalog.columns.flag }}</th>
                        <th>{{ t:ui.labels.scope }}</th>
                        <th>{{ t:settings.feature_flags.catalog.columns.owner }}</th>
                        <th>{{ t:ui.labels.state }}</th>
                        <th class="text-end">{{ t:ui.datagrid.action }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#each catalog_rows}}
                        <tr>
                            <td>
                                <div class="fw-semibold">{{ label }}</div>
                                <div class="small text-muted"><code>{{ key }}</code></div>
                                {{#if has_description}}
                                    <div class="small text-muted mt-1">{{ description }}</div>
                                {{/if}}
                            </td>
                            <td><span class="badge text-bg-light">{{ scope_label }}</span></td>
                            <td><code>{{ managed_by }}</code></td>
                            <td>
                                <span class="badge {{ state_badge_class }}">{{ state_label }}</span>
                            </td>
                            <td class="text-end">
                                {{#if read_only}}
                                    <span class="badge text-bg-dark">{{ read_only_label }}</span>
                                {{else}}
                                    <form data-catalyst="form" method="POST" action="{{ toggle_url }}" class="d-inline">
                                        {{{ @root.csrfField }}}
                                        <input type="hidden" name="enabled" value="{{ toggle_enabled_value }}">
                                        <button type="submit" class="btn btn-sm {{ toggle_button_class }}">
                                            {{ toggle_label }}
                                        </button>
                                    </form>
                                {{/if}}
                            </td>
                        </tr>
                    {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-xl-4">
            {{> "components._form-builder" }}
        </div>
        <div class="col-xl-8">
            {{> "components._datagrid" }}
        </div>
    </div>
</div>
