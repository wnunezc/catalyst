<div class="surface-page surface-page-shell surface-content-shell surface-content-shell--xl settings-console">
    {{> "components._page-header" }}

    {{#unless configured}}
        <div class="alert alert-warning d-flex align-items-center gap-2 py-2 small mb-3">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>{{ t:settings.settings.not_configured }}</span>
        </div>
    {{/unless}}

    {{> "../partials/_settings-grid" }}
    {{> "../partials/_settings-setup-actions" }}
</div>

{{> "../partials/_settings-modals" }}
