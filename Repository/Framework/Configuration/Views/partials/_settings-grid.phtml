<div>
    {{#each settingsGroups}}
        <section class="mb-3" id="settings-group-{{ this.id }}">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center mb-2">
                <div>
                    <div class="small text-uppercase text-muted fw-semibold">{{ this.eyebrow }}</div>
                    <h5 class="mb-0" data-settings-group-title>{{ this.title }}</h5>
                </div>
                <p class="text-muted mb-0 text-lg-end">{{ this.description }}</p>
            </div>
            <div class="row g-2">
                {{#each this.cards}}
                    <div class="{{ this.colClass }}">
                        {{> ./_settings-card }}
                    </div>
                {{/each}}

                {{#if this.includesDkim}}
                    <div class="col-xxl-4 col-xl-4 col-lg-6">
                        {{> ./_settings-dkim-card }}
                    </div>
                {{/if}}
            </div>
        </section>
    {{/each}}
</div>
