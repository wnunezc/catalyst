<li class="list-group-item surface-kv-row">
    <span class="surface-kv-label">{{ label }}</span>
    {{#if is_boolean}}
        <span id="{{ id }}" class="surface-kv-value">
            <span class="badge {{ badge_class }}">{{ text }}</span>
        </span>
    {{else}}
        <span id="{{ id }}" class="surface-kv-value{{ text_class }}">{{ text }}</span>
    {{/if}}
</li>
