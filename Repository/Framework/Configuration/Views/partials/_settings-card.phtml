<div class="card h-100">
    <div class="card-header d-flex align-items-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-2">
            <span><i class="{{ this.icon }}"></i></span>
            <h6 class="mb-0 fw-semibold">{{ this.title }}</h6>
        </div>
        {{#if this.modalId}}
            <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#{{ this.modalId }}">
                <i class="{{ this.actionIcon }}"></i><span>{{ this.actionLabel }}</span>
            </button>
        {{/if}}
    </div>
    {{#if this.notice}}
        <div class="mx-3 mt-3">
            <div class="alert alert-warning py-2 px-2 small mb-0">{{ this.notice }}</div>
        </div>
    {{/if}}
    <ul class="list-group list-group-flush">
        {{#each this.rows}}
            {{> ./_settings-row }}
        {{/each}}
    </ul>
</div>
