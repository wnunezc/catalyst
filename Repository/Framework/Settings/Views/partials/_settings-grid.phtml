<div class="settings-command-grid">
    {{#each settingsGroups}}
        <section class="settings-command-section mb-3" id="settings-group-{{ this.id }}">
            <div class="settings-command-section__header">
                <div>
                    <div class="settings-command-section__eyebrow">{{ this.eyebrow }}</div>
                    <h5 class="settings-command-section__title">{{ this.title }}</h5>
                </div>
                <p class="settings-command-section__description">{{ this.description }}</p>
            </div>
            <div class="row g-2 settings-card-grid">
                {{#each this.cards}}
                    <div class="{{ this.colClass }}">
                        {{> ./_settings-card }}
                    </div>
                {{/each}}

                {{#if this.includesDkim}}
                    <div class="col-xxl-4 col-xl-4 col-lg-6">
                        {{> ./_settings-dkim-card }}
                    </div>
                {{/if}}
            </div>
        </section>
    {{/each}}
</div>
