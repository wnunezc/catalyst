<section class="card settings-reference-card mb-3">
    <div class="card-header settings-reference-card__header">
        <div>
            <h6 class="mb-1 fw-semibold">{{ t:settings.runtime_surfaces.title }}</h6>
            <p class="text-muted small mb-0">{{ t:settings.runtime_surfaces.description }}</p>
        </div>
        {{#if configured}}
            <button type="button" class="btn btn-sm btn-primary" data-catalyst-href="{{ operationsUrl }}">{{ t:settings.runtime_surfaces.open_operations }}</button>
        {{/if}}
    </div>
    <div class="card-body py-2">
        <div class="row g-2">
            <div class="col-lg-4">
                <div class="settings-reference-tile">
                    <div class="settings-reference-tile__eyebrow">{{ t:settings.runtime_surfaces.cards.setup.eyebrow }}</div>
                    <h6>`/configuration/environment-setup`</h6>
                    <p>{{ t:settings.runtime_surfaces.cards.setup.description }}</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="settings-reference-tile">
                    <div class="settings-reference-tile__eyebrow">{{ t:settings.runtime_surfaces.cards.operations.eyebrow }}</div>
                    <h6>`/operations`</h6>
                    <p>{{ t:settings.runtime_surfaces.cards.operations.description }}</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="settings-reference-tile">
                    <div class="settings-reference-tile__eyebrow">{{ t:settings.runtime_surfaces.cards.devtools.eyebrow }}</div>
                    <h6>`/test-features`</h6>
                    <p>{{ t:settings.runtime_surfaces.cards.devtools.description }}</p>
                </div>
            </div>
        </div>
    </div>
</section>
