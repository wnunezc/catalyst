<div class="surface-page surface-page-shell">
    {{> "components._page-header" }}

    <section class="card mb-3">
        <div class="card-header">
            <div class="d-flex align-items-center flex-wrap gap-3 justify-content-between">
                <div>
                    <h2 class="card-title mb-1">{{ t:roles.organization_hierarchy.organizations }}</h2>
                    <p class="text-muted mb-0">{{ t:roles.organization_hierarchy.organizations_help }}</p>
                </div>
                <span class="rbac-chip">{{ organizationCountLabel }}</span>
            </div>
        </div>
        <div class="card-body">
            <form data-catalyst="form" method="POST" action="/users/organization-hierarchy/organizations" class="row g-3 mb-4">
                {{{ csrfField }}}
                <div class="col-md-4">
                    <label class="form-label" for="org-name">{{ t:roles.common.name }}</label>
                    <input class="form-control" id="org-name" name="name" maxlength="160" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="org-slug">{{ t:roles.common.slug }}</label>
                    <input class="form-control" id="org-slug" name="slug" maxlength="120" pattern="[a-z0-9][a-z0-9-]*" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="org-description">{{ t:roles.common.description_optional }}</label>
                    <input class="form-control" id="org-description" name="description" maxlength="255">
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button class="btn btn-primary w-100" type="submit">{{ t:roles.organization_hierarchy.save }}</button>
                </div>
            </form>
            {{#if organizationRows}}
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead><tr><th>{{ t:roles.common.name }}</th><th>{{ t:roles.common.slug }}</th><th>{{ t:roles.common.description }}</th><th>{{ t:roles.common.actions }}</th></tr></thead>
                        <tbody>
                        {{#each organizationRows}}
                            <tr>
                                <td><input class="form-control form-control-sm" form="org-update-{{ id }}" name="name" value="{{ name }}" maxlength="160" required></td>
                                <td><code>{{ slug }}</code></td>
                                <td><input class="form-control form-control-sm" form="org-update-{{ id }}" name="description" value="{{ description }}" maxlength="255"></td>
                                <td>
                                    <form id="org-update-{{ id }}" data-catalyst="form" method="POST" action="/users/organization-hierarchy/organizations" class="d-inline">
                                        {{{ csrfField }}}
                                        <input type="hidden" name="slug" value="{{ slug }}">
                                        <button class="btn btn-outline-primary btn-sm" type="submit">{{ t:roles.organization_hierarchy.update }}</button>
                                    </form>
                                    {{#if is_locked}}
                                        <span class="badge text-bg-secondary">{{ lock_reason }}</span>
                                    {{else}}
                                        <form data-catalyst="form" method="POST" action="{{ delete_action }}" class="d-inline">
                                            {{{ csrfField }}}
                                            <button class="btn btn-outline-danger btn-sm" type="submit">{{ t:roles.common.delete }}</button>
                                        </form>
                                    {{/if}}
                                </td>
                            </tr>
                        {{/each}}
                        </tbody>
                    </table>
                </div>
            {{/if}}
        </div>
    </section>

    <section class="card mb-3">
        <div class="card-header"><h2 class="card-title mb-0">{{ t:roles.organization_hierarchy.scopes }}</h2></div>
        <div class="card-body">
            <form data-catalyst="form" method="POST" action="/users/organization-hierarchy/scopes" class="row g-3 mb-4">
                {{{ csrfField }}}
                <div class="col-md-3">
                    <label class="form-label" for="scope-organization">{{ t:roles.organization_hierarchy.organization }}</label>
                    <select class="form-select" id="scope-organization" name="organization_id" required>
                        {{#each organizationOptions}}<option value="{{ value }}">{{ label }}</option>{{/each}}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="scope-key">{{ t:roles.organization_hierarchy.scope_key }}</label>
                    <input class="form-control" id="scope-key" name="scope_key" maxlength="120" pattern="[a-z0-9][a-z0-9-]*" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="scope-label">{{ t:roles.organization_hierarchy.label }}</label>
                    <input class="form-control" id="scope-label" name="label" maxlength="160" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="scope-token">{{ t:roles.organization_hierarchy.visual_token }}</label>
                    <input class="form-control" id="scope-token" name="visual_token" maxlength="80" pattern="[a-z0-9][a-z0-9-]*">
                </div>
                <div class="col-md-1">
                    <label class="form-label" for="scope-color">{{ t:roles.organization_hierarchy.color }}</label>
                    <input class="form-control" id="scope-color" name="color" maxlength="7" placeholder="#1f7a8c">
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button class="btn btn-primary w-100" type="submit">{{ t:roles.organization_hierarchy.save }}</button>
                </div>
            </form>
            {{#if scopeRows}}
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead><tr><th>{{ t:roles.organization_hierarchy.organization }}</th><th>{{ t:roles.organization_hierarchy.scope_key }}</th><th>{{ t:roles.organization_hierarchy.label }}</th><th>{{ t:roles.common.actions }}</th></tr></thead>
                        <tbody>
                        {{#each scopeRows}}
                            <tr>
                                <td>{{ organization_name }}</td>
                                <td><code>{{ scope_key }}</code></td>
                                <td><input class="form-control form-control-sm" form="scope-update-{{ id }}" name="label" value="{{ label }}" maxlength="160" required></td>
                                <td>
                                    <form id="scope-update-{{ id }}" data-catalyst="form" method="POST" action="/users/organization-hierarchy/scopes" class="d-inline">
                                        {{{ csrfField }}}
                                        <input type="hidden" name="organization_id" value="{{ organization_id }}">
                                        <input type="hidden" name="scope_key" value="{{ scope_key }}">
                                        <input type="hidden" name="visual_token" value="">
                                        <input type="hidden" name="color" value="">
                                        <button class="btn btn-outline-primary btn-sm" type="submit">{{ t:roles.organization_hierarchy.update }}</button>
                                    </form>
                                    {{#if is_locked}}
                                        <span class="badge text-bg-secondary">{{ lock_reason }}</span>
                                    {{else}}
                                        <form data-catalyst="form" method="POST" action="{{ delete_action }}" class="d-inline">
                                            {{{ csrfField }}}
                                            <button class="btn btn-outline-danger btn-sm" type="submit">{{ t:roles.common.delete }}</button>
                                        </form>
                                    {{/if}}
                                </td>
                            </tr>
                        {{/each}}
                        </tbody>
                    </table>
                </div>
            {{/if}}
        </div>
    </section>

