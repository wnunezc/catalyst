                                        <input type="hidden" name="code" value="{{ code }}">
                                        <input type="hidden" name="visual_token" value="">
                                        <button class="btn btn-outline-primary btn-sm" type="submit">{{ t:roles.organization_hierarchy.update }}</button>
                                    </form>
                                    {{#if is_locked}}
                                        <span class="badge text-bg-secondary">{{ lock_reason }}</span>
                                    {{else}}
                                        <form data-catalyst="form" method="POST" action="{{ delete_action }}" class="d-inline">
                                            {{{ csrfField }}}
                                            <button class="btn btn-outline-danger btn-sm" type="submit">{{ t:roles.common.delete }}</button>
                                        </form>
                                    {{/if}}
                                </td>
                            </tr>
                        {{/each}}
                        </tbody>
                    </table>
                </div>
            {{/if}}
        </div>
    </section>

