<div class="surface-page surface-page-shell">
    {{> "components._page-header" }}

    {{> "components._record-presence" }}

    <section class="card">
        <div class="card-header">
            <div class="d-flex align-items-center flex-wrap gap-3 justify-content-between">
                <div>
                    <h2 class="card-title mb-1">{{ t:roles.permissions.assignment_title }}</h2>
                    <p class="text-muted mb-0">{{ t:roles.permissions.assignment_description }}</p>
                </div>
                <span class="rbac-chip">{{ availablePermissionCountLabel }}</span>
            </div>
        </div>
        <div class="card-body">
            {{#unless permissionRows}}
                <div class="d-flex flex-column align-items-center justify-content-center text-center py-5">
                    <span><i class="fa-solid fa-key"></i></span>
                    <h2 class="h5 mb-2">{{ t:roles.permissions.none_defined }}</h2>
                    <p class="text-muted mb-3">{{ t:roles.permissions.create_first }}</p>
                    <button type="button" class="btn btn-sm btn-primary" data-catalyst-href="/users/permissions/create">
                        <i class="fa-solid fa-plus me-1"></i> {{ t:roles.permissions.new }}
                    </button>
                </div>
            {{/unless}}
            {{#if permissionRows}}
                <form data-catalyst="form" method="POST" action="{{ permissionsAction }}">
                    {{{ csrfField }}}
                    {{#if claimToken}}
                        <input type="hidden" name="claim_token" value="{{ claimToken }}">
                    {{/if}}

                    <div class="row g-3 mb-4">
                        {{#each permissionRows}}
                            <label class="col-12 col-lg-6" for="{{ input_id }}">
                                <span class="border rounded p-3 h-100 d-flex align-items-start gap-2" data-role-permission-option>
                                    <input type="checkbox"
                                           class="form-check-input flex-shrink-0 mt-1"
                                           id="{{ input_id }}"
                                           name="permissions[]"
                                           value="{{ value }}"
                                           {{#if checked}}checked{{/if}}>
                                    <span class="d-grid gap-1">
                                        <span>{{ display_name }}</span>
                                        <code class="text-break">{{ slug }}</code>
                                    </span>
                                </span>
                            </label>
                        {{/each}}
                    </div>

                    <button type="submit" class="btn btn-primary">{{ t:roles.permissions.save }}</button>
                </form>
            {{/if}}
        </div>
    </section>
</div>
