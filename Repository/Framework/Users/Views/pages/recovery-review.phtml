<div class="surface-page surface-page-shell users-page" data-account-recovery-review="detail">
    {{> "components._page-header" }}

    <div class="row g-3">
        <div class="col-12 col-xl-8">
            <div class="card h-100">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">{{ t:account.review.index.columns.type }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.request_type_label }}</dd>
                        <dt class="col-sm-4">{{ t:account.review.index.columns.status }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.status_label }}</dd>
                        <dt class="col-sm-4">{{ t:account.forms.known_email }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.known_email }}</dd>
                        <dt class="col-sm-4">{{ t:account.forms.alternate_email }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.alternate_email }}</dd>
                        <dt class="col-sm-4">{{ t:account.review.index.columns.created }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.created_at }}</dd>
                        <dt class="col-sm-4">{{ t:account.review.show.reviewed_at }}</dt>
                        <dd class="col-sm-8">{{ recovery_request.reviewed_at }}</dd>
                        <dt class="col-sm-4">{{ t:account.forms.message }}</dt>
                        <dd class="col-sm-8 text-break">{{ recovery_request.message }}</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-4">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5">{{ t:account.review.show.review_title }}</h2>
                    <p class="text-muted">{{ t:account.review.show.review_hint }}</p>
                    {{#if recovery_request.can_review}}
                    <div class="d-grid gap-2">
                        <form method="POST" action="/users/account-recovery/{{ recovery_request.id }}/approve" data-catalyst="form">
                            {{{ csrf_field }}}
                            <button type="submit" class="btn btn-success w-100">{{ t:account.review.show.approve }}</button>
                        </form>
                        <form method="POST" action="/users/account-recovery/{{ recovery_request.id }}/reject" data-catalyst="form">
                            {{{ csrf_field }}}
                            <button type="submit" class="btn btn-outline-danger w-100">{{ t:account.review.show.reject }}</button>
                        </form>
                    </div>
                    {{else}}
                    <div class="alert alert-info mb-0">{{ t:account.review.show.already_reviewed }}</div>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
</div>
