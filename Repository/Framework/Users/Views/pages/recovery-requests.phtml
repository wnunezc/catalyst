<div class="surface-page surface-page-shell users-page" data-account-recovery-review="requests">
    {{> "components._page-header" }}

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                    <tr>
                        <th>{{ t:account.review.index.columns.id }}</th>
                        <th>{{ t:account.review.index.columns.type }}</th>
                        <th>{{ t:account.review.index.columns.status }}</th>
                        <th>{{ t:account.review.index.columns.email }}</th>
                        <th>{{ t:account.review.index.columns.created }}</th>
                        <th class="text-end">{{ t:account.review.index.columns.action }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#each recovery_requests}}
                    <tr>
                        <td>#{{ id }}</td>
                        <td>{{ request_type_label }}</td>
                        <td><span class="badge bg-secondary-subtle text-secondary-emphasis">{{ status_label }}</span></td>
                        <td>
                            <span class="d-block">{{ known_email }}</span>
                            <small class="text-muted">{{ alternate_email }}</small>
                        </td>
                        <td>{{ created_at }}</td>
                        <td class="text-end">
                            <a href="/users/account-recovery/{{ id }}" class="btn btn-outline-primary btn-sm">{{ t:account.review.index.view }}</a>
                        </td>
                    </tr>
                    {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
