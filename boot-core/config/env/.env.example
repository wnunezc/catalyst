# Catalyst Framework — Environment Fallback
#
# IMPORTANT: Este archivo es el fallback del sistema para parámetros que NO
# pueden vivir en JSON (secrets, credenciales, valores pre-configuración).
# Todo lo que pueda configurarse via /setup vive en boot-core/config/{env}/*.json
# Los parámetros aquí son los mínimos requeridos para que el framework arranque.
#
# Copia este archivo como .env y completa los valores marcados con <REPLACE>.

# ── Entorno ───────────────────────────────────────────────────────────────────
# Valores: development | staging | testing | production
APP_ENV=development

# ── Clave de aplicación (secret) ─────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios. NUNCA commitear el valor real.
APP_KEY=<REPLACE_WITH_32_CHAR_RANDOM_STRING>

# ── Base de datos (credenciales — nunca en JSON) ──────────────────────────────
DB_PASSWORD=<REPLACE_WITH_DB_PASSWORD>

# ── Mail (credenciales) ───────────────────────────────────────────────────────
MAIL_PASSWORD=<REPLACE_WITH_MAIL_PASSWORD>

# ── FTP (credenciales) ────────────────────────────────────────────────────────
FTP_PASSWORD=<REPLACE_WITH_FTP_PASSWORD>

# ── Sesión (nombre — fallback hasta que /setup escriba session.json) ──────────
SESSION_NAME=catalyst-session
SESSION_LIFE_TIME=2592000
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Strict
SESSION_DOMAIN=

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
APP_DISPLAY_LOGS=true

# ── OAuth secrets (si aplica) ─────────────────────────────────────────────────
# OAUTH_GOOGLE_CLIENT_ID=<REPLACE>
# OAUTH_GOOGLE_CLIENT_SECRET=<REPLACE>
# OAUTH_GITHUB_CLIENT_ID=<REPLACE>
# OAUTH_GITHUB_CLIENT_SECRET=<REPLACE>

# ── Tooling local opcional ────────────────────────────────────────────────────
# Ruta del CLI dentro del contenedor Docker cuando dev:export-overlay usa
# fallback de contenedor. Solo hace falta en stacks Docker/WSDD personalizados.
# CATALYST_DOCKER_CLI_PATH=/var/www/html/public/cli.php
