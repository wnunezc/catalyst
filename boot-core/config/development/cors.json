{
    "cors": {
        "enabled": true,
        "allowed_origins": [
            "*"
        ],
        "allowed_methods": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE",
            "OPTIONS"
        ],
        "allowed_headers": [
            "Content-Type",
            "Authorization",
            "X-Requested-With",
            "X-CSRF-TOKEN"
        ],
        "exposed_headers": [],
        "allow_credentials": false,
        "max_age": 86400
    }
}