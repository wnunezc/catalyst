{
    "security": {
        "bcrypt_rounds": 12,
        "mfa_enabled": false,
        "password_policy": {
            "min_length": 12,
            "require_uppercase": true,
            "require_lowercase": true,
            "require_number": true,
            "require_symbol": true,
            "block_common": true,
            "common_passwords": []
        },
        "uploads": {
            "allow_svg": false,
            "blocked_extensions": [
                "php",
                "phtml",
                "phar",
                "cgi",
                "pl",
                "htm",
                "html",
                "svg"
            ],
            "blocked_mime_types": [
                "application/x-php",
                "text/html",
                "image/svg+xml"
            ]
        }
    }
}
