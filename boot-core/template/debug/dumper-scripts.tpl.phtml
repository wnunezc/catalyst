<script{{{ nonce_attr }}}>
    {{{ collapsible_js }}}

    (function () {
        var modal = document.getElementById({{{ modal_id_js }}});
        if (!modal) return;
        window.addEventListener("click", function (event) {
            if (event.target === modal) {
                modal.style.display = "none";
            }
        });
    })();

    if (!window.__catalystDumperToggleBound) {
        window.__catalystDumperToggleBound = true;
        document.addEventListener("click", function (e) {
            var t = e.target;
            while (t && t !== document.body) {
                if (t.hasAttribute && t.hasAttribute("data-dumper-toggle")) {
                    var id = t.getAttribute("data-dumper-toggle");
                    var modal = document.getElementById(id);
                    if (modal) {
                        modal.style.display = (modal.style.display === "block") ? "none" : "block";
                    }
                    return;
                }
                t = t.parentElement;
            }
        });
    }
</script>
