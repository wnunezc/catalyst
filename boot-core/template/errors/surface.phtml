<section class="card" aria-labelledby="error-title">
    <div class="card-body">
        <div class="error-brand">
            <span class="error-status" aria-hidden="true">{{ error_status }}</span>
            <span class="error-eyebrow">Catalyst Framework</span>
        </div>

        <h1 id="error-title" class="error-title">{{ error_title }}</h1>
        <p class="error-message">{{ error_message }}</p>

        <dl class="error-meta">
            <div>
                <dt>{{ t:ui.errors.request_path }}</dt>
                <dd><code>{{ request_path }}</code></dd>
            </div>
            {{#if has_error_ticket}}
            <div>
                <dt>{{ t:ui.errors.error_ticket }}</dt>
                <dd><code>{{ error_ticket }}</code></dd>
            </div>
            {{/if}}
        </dl>

        <div class="error-actions">
            <a href="/" class="btn btn-primary">{{ t:ui.errors.go_home }}</a>
            {{#if show_login_action}}
            <a href="/login" class="btn btn-outline-secondary">{{ t:ui.errors.sign_in }}</a>
            {{/if}}
        </div>
    </div>
</section>
