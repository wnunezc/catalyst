{{#if is_hidden}}
    <input type="hidden" id="{{ id }}" name="{{ name }}" value="{{ value }}">
{{else}}
    {{#if is_repeater}}
        <div class="d-grid gap-3"
             data-admin-repeater="1"
             data-repeater-name="{{ name }}"
             data-repeater-min-items="{{ min_items }}"
             data-repeater-max-items="{{ max_items }}">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div>
                    <h3 class="h6 mb-1">{{ repeater_label }}</h3>
                    {{#if has_help}}<p class="text-muted small mb-0">{{ help }}</p>{{/if}}
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-repeater-add>
                    <i class="fa-solid fa-plus me-1"></i>{{ add_label }}
                </button>
            </div>

            <div class="d-grid gap-3" data-repeater-items>
                {{#if has_items}}
                    {{#each items}}
                        <div class="border rounded-3 p-3 d-grid gap-3" data-repeater-item>
                            <div class="d-flex justify-content-between align-items-center gap-3">
                                <span class="small text-uppercase text-muted fw-semibold">{{ index_label }}</span>
                                <button type="button" class="btn btn-outline-danger btn-sm" data-repeater-remove>
                                    <i class="fa-solid fa-trash me-1"></i>{{ remove_label }}
                                </button>
                            </div>
                            <div class="row g-3">
                                {{#each fields}}
                                    {{> "./_field-block" }}
                                {{/each}}
                            </div>
                        </div>
                    {{/each}}
                {{else}}
                    <div class="border rounded-3 p-3 text-muted small" data-repeater-empty>
                        {{ empty_label }}
                    </div>
                {{/if}}
            </div>

            <template data-repeater-template>
                <div class="border rounded-3 p-3 d-grid gap-3" data-repeater-item>
                    <div class="d-flex justify-content-between align-items-center gap-3">
                        <span class="small text-uppercase text-muted fw-semibold">{{ template_index_label }}</span>
                        <button type="button" class="btn btn-outline-danger btn-sm" data-repeater-remove>
                            <i class="fa-solid fa-trash me-1"></i>{{ remove_label }}
                        </button>
                    </div>
                    <div class="row g-3">
                        {{#each template_fields}}
                            {{> "./_field-block" }}
                        {{/each}}
                    </div>
                </div>
            </template>
        </div>
    {{else}}
        {{#if is_textarea}}
            <textarea id="{{ id }}"
                      name="{{ name }}"
                      class="form-control{{ invalid_class }}"
                      placeholder="{{ placeholder }}"{{{ attributes_html }}}>{{ textarea_value }}</textarea>
        {{else}}
            {{#if is_select}}
                {{#if is_multiple}}
                    <input type="hidden" name="{{ base_name }}" value="">
                {{/if}}
                <select id="{{ id }}"
                        name="{{ name }}"
                        class="form-select{{ invalid_class }}"{{{ attributes_html }}}>
                    {{#if has_empty_option}}
                        <option value="">{{ empty_option_label }}</option>
                    {{/if}}
                    {{#each options}}
                        <option value="{{ value }}"{{#if selected}} selected{{/if}}>{{ label }}</option>
                    {{/each}}
                </select>
            {{else}}
                {{#if is_checkbox}}
                    <input type="hidden" name="{{ name }}" value="{{ checkbox_hidden_value }}">
                    <div class="form-check">
                        <input type="checkbox"
                               id="{{ id }}"
                               name="{{ name }}"
                               value="{{ checkbox_checked_value }}"
                               class="form-check-input{{ invalid_class }}"{{#if checkbox_checked}} checked{{/if}}{{{ attributes_html }}}>
                        <label for="{{ id }}" class="form-check-label">
                            {{ checkbox_label }}
                        </label>
                    </div>
                {{else}}
                    <input type="{{ input_type }}"
                           id="{{ id }}"
                           name="{{ name }}"
                           class="form-control{{ invalid_class }}"
                           value="{{ value }}"
                           placeholder="{{ placeholder }}"{{{ attributes_html }}}>
                {{/if}}
            {{/if}}
        {{/if}}

        {{#if has_error}}
            <div class="invalid-feedback d-block">{{ error }}</div>
        {{/if}}
    {{/if}}
{{/if}}
