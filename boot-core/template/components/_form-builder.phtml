<form method="{{ http_method }}"
      action="{{ action }}"
      class="{{ wrapper_class }}"{{{ form_attributes_html }}}
      data-catalyst="form"
      data-form-builder="form">
    {{#if include_csrf}}
        {{{ csrfField }}}
    {{/if}}

    {{#if include_method_override}}
        <input type="hidden" name="_method" value="{{ method }}">
    {{/if}}

    {{#if grouped_sections}}
        <div class="col-12">
            <section class="card border-0 shadow-sm" data-form-builder-layout="grouped-card">
                <div class="card-body">
                    {{#each sections}}
                        <section class="row g-3 border-bottom pb-4 mb-4 {{ section_class }}" data-form-builder-section>
                            <div class="col-12 col-lg-3">
                                {{#if section_title}}<h2 class="h5 mb-1">{{ section_title }}</h2>{{/if}}
                                {{#if section_description}}<p class="text-muted mb-0">{{ section_description }}</p>{{/if}}
                            </div>
                            <div class="col-12 col-lg-9">
                                <div class="{{ fields_wrapper_class }}">
                                    {{#each fields}}
                                        {{> "./form-builder/_field-block" }}
                                    {{/each}}
                                </div>
                            </div>
                        </section>
                    {{/each}}
                </div>
                {{#if has_actions}}
                    <div class="card-footer d-flex gap-2 flex-wrap justify-content-end">
                        {{#each actions}}
                            {{#if is_link}}
                                <button type="button" class="{{ class }}" data-catalyst-href="{{ href }}"{{{ attributes_html }}}>
                                    {{#if has_icon}}<i class="{{ icon }} me-1"></i>{{/if}}
                                    {{ label }}
                                </button>
                            {{else}}
                                <button type="{{ type }}" class="{{ class }}"{{{ attributes_html }}}>
                                    {{#if has_icon}}<i class="{{ icon }} me-1"></i>{{/if}}
                                    {{ label }}
                                </button>
                            {{/if}}
                        {{/each}}
                    </div>
                {{/if}}
            </section>
        </div>
    {{else}}
        {{#each sections}}
            {{#if has_header}}
                <div class="{{ section_col_class }}">
                    <section class="card border-0 shadow-sm {{ section_class }}">
                        <div class="card-header">
                            <div>
                                {{#if section_title}}<h2 class="h5 mb-1">{{ section_title }}</h2>{{/if}}
                                {{#if section_description}}<p class="text-muted mb-0">{{ section_description }}</p>{{/if}}
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="{{ fields_wrapper_class }}">
                                {{#each fields}}
                                    {{> "./form-builder/_field-block" }}
                                {{/each}}
                            </div>
                        </div>
                    </section>
                </div>
            {{else}}
                {{#each fields}}
                    {{> "./form-builder/_field-block" }}
                {{/each}}
            {{/if}}
        {{/each}}

        {{#if has_actions}}
            <div class="col-12 d-flex gap-2 flex-wrap">
                {{#each actions}}
                    {{#if is_link}}
                        <button type="button" class="{{ class }}" data-catalyst-href="{{ href }}"{{{ attributes_html }}}>
                            {{#if has_icon}}<i class="{{ icon }} me-1"></i>{{/if}}
                            {{ label }}
                        </button>
                    {{else}}
                        <button type="{{ type }}" class="{{ class }}"{{{ attributes_html }}}>
                            {{#if has_icon}}<i class="{{ icon }} me-1"></i>{{/if}}
                            {{ label }}
                        </button>
                    {{/if}}
                {{/each}}
            </div>
        {{/if}}
    {{/if}}
</form>
