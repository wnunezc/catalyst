<nav class="catalyst-public-nav" aria-label="{{ t:ui.shell.public_routes }}">
    <div class="container-fluid catalyst-public-nav__shell">
        <a href="/" class="catalyst-public-brand" aria-label="{{ brand_name }}">
            {{#if has_brand_logo}}
            <span class="catalyst-public-brand__mark">
                <span class="catalyst-brand-logo-stack">
                    <img src="{{ brand_logo_light_url }}" alt="{{ brand_alt }}" class="catalyst-brand-logo catalyst-brand-logo--light">
                    <img src="{{ brand_logo_dark_url }}" alt="{{ brand_alt }}" class="catalyst-brand-logo catalyst-brand-logo--dark">
                </span>
            </span>
            {{/if}}
            <span class="catalyst-public-brand__copy">
                <span class="catalyst-public-brand__name">{{ brand_name }}</span>
                {{#if has_brand_tagline}}
                <span class="catalyst-public-brand__tagline">{{ brand_tagline }}</span>
                {{/if}}
            </span>
        </a>

        <div class="catalyst-public-nav__actions">
            {{#each public_navigation_items}}
            <a href="{{ href }}" class="{{ link_class }}"{{#if is_active}} aria-current="page"{{/if}}>
                {{ label }}
            </a>
            {{/each}}
        </div>
    </div>
</nav>
