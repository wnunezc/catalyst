<section class="card"
         data-datagrid="1"
         {{#if grid_has_bulk}}data-grid-selection-name="{{ grid_bulk_name }}"
         data-grid-selection-empty="{{ grid_selection_empty_label }}"
         data-grid-selection-template="{{ grid_selection_template_label }}"{{/if}}>
    <div class="card-header">
        <div>
            <h2 class="datagrid-title">{{ grid_title }}</h2>
            {{#if grid_subtitle}}
                <p class="datagrid-subtitle">{{ grid_subtitle }}</p>
            {{/if}}
        </div>
        <span class="badge badge-soft-primary badge-label">{{ grid_records_label }}</span>
    </div>

    {{#if grid_is_empty}}
        <div class="card-body">
            <div class="datagrid-empty-state">
                <span class="datagrid-empty-state__icon"><i class="ti ti-table"></i></span>
                <h2 class="h5 mb-2">{{ grid_empty_title }}</h2>
                <p class="text-muted mb-3">{{ grid_empty_message }}</p>
                {{#if grid_empty_action}}
                    <button type="button"
                            class="{{ grid_empty_action.class }}"
                            data-catalyst-href="{{ grid_empty_action.href }}">
                        {{#if grid_empty_action.has_icon}}<i class="{{ grid_empty_action.icon }} me-1"></i>{{/if}}
                        {{ grid_empty_action.label }}
                    </button>
                {{/if}}
            </div>
        </div>
    {{else}}
        <div class="card-body border-bottom py-2 datagrid-filterbar">
            <form method="GET" action="{{ grid_base_url }}" class="row g-2 align-items-end">
                <div class="col-xl-4 col-lg-5 col-md-6">
                    <label for="grid-search" class="form-label">{{ t:ui.datagrid.search }}</label>
                    <input type="search"
                           id="grid-search"
                           name="{{ grid_search_name }}"
                           value="{{ grid_search_value }}"
                           class="form-control form-control-sm"
                           placeholder="{{ grid_search_placeholder }}">
                </div>

                {{#each grid_filters}}
                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <label for="filter-{{ name }}" class="form-label">{{ label }}</label>
                        {{#if is_select}}
                            <select id="filter-{{ name }}" name="{{ name }}" class="form-select form-select-sm">
                                <option value="">{{ t:ui.datagrid.all }}</option>
                                {{#each options}}
                                    <option value="{{ value }}"{{#if selected}} selected{{/if}}>{{ label }}</option>
                                {{/each}}
                            </select>
                        {{else}}
                            <input type="text"
                                   id="filter-{{ name }}"
                                   name="{{ name }}"
                                   value="{{ value }}"
                                   class="form-control form-control-sm"
                                   placeholder="{{ placeholder }}">
                        {{/if}}
                    </div>
                {{/each}}

                <input type="hidden" name="sort" value="{{ grid_query_sort }}">
                <input type="hidden" name="direction" value="{{ grid_query_direction }}">
                <input type="hidden" name="per_page" value="{{ grid_current_per_page }}">

                <div class="col-xl-12 d-flex gap-2 flex-wrap datagrid-filterbar__actions">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="ti ti-filter me-1"></i> {{ t:ui.datagrid.apply }}
                    </button>
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm"
                            data-catalyst-href="{{ grid_base_url }}">
                        <i class="ti ti-rotate-clockwise-2 me-1"></i> {{ t:ui.datagrid.reset }}
                    </button>
                </div>
            </form>
        </div>

        <div class="card-body py-0">
            <div class="border-bottom py-2">
                {{> "./_datagrid-toolbar" }}
            </div>
        </div>

        {{#if grid_has_bulk}}
            <form method="POST"
                  action="{{ grid_base_url }}"
                  id="{{ grid_bulk_form_id }}"
                  data-catalyst="form">
                {{{ grid_bulk_csrf_field }}}
            </form>

            <div class="card-body border-bottom py-2 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-2">
                <div class="small text-muted" data-grid-selection-summary>{{ grid_selection_empty_label }}</div>
                <div class="d-flex gap-2 flex-wrap">
                    {{#each grid_bulk_actions}}
                        <button type="submit"
                                form="{{ form_id }}"
                                formaction="{{ href }}"
                                formmethod="{{ method }}"
                                class="{{ class }}"{{#if has_confirm}}
                                data-confirm="{{ confirm }}"{{/if}}
                                data-grid-bulk-action
                                disabled>
                            {{#if has_icon}}<i class="{{ icon }} me-1"></i>{{/if}}
                            {{ label }}
                        </button>
                    {{/each}}
                </div>
            </div>
        {{/if}}

        <div class="{{ grid_table_body_class }}">
            <div class="table-responsive {{ grid_table_scroll_class }}"
                 data-grid-visible-columns="{{ grid_visible_column_count }}"
                 data-grid-visible-character-limit="{{ grid_visible_character_limit }}">
                <table data-catalyst-datatable="progressive"
                       data-empty-label="{{ grid_empty_title }}"
                       class="{{ grid_table_class }}">
                    <thead class="thead-sm text-uppercase fs-xxs">
                    <tr>
                        {{#if grid_has_bulk}}
                            <th class="text-center" data-dt-order="disable">
                                <input type="checkbox" class="form-check-input" data-grid-select-all>
                            </th>
                        {{/if}}

                        {{#each grid_columns}}
                            <th class="{{ header_class }}">
                                {{#if sortable}}
                                    <a href="{{ sort_url }}" class="datagrid-sort-link d-inline-flex align-items-center gap-1">
                                        <span>{{ label }}</span>
                                        {{#if sort_active}}
                                            <i class="ti {{ sort_icon_class }}"></i>
                                        {{else}}
                                            <i class="ti ti-arrows-sort text-muted"></i>
                                        {{/if}}
                                    </a>
                                {{else}}
                                    {{ label }}
                                {{/if}}
                            </th>
                        {{/each}}

                        {{#if grid_has_row_actions}}
                            <th class="text-end" data-dt-order="disable">{{ t:ui.datagrid.actions }}</th>
                        {{/if}}
                    </tr>
                    </thead>
                    <tbody>
                    {{#each grid_rows}}
                        <tr>
                            {{#if row_has_bulk}}
                                <td class="text-center">
                                    {{#if has_checkbox}}
                                        <input type="checkbox"
                                               class="form-check-input"
                                               form="{{ row_bulk_form_id }}"
                                               name="{{ row_bulk_name }}[]"
                                               value="{{ key }}"
                                               data-grid-row-checkbox>
                                    {{/if}}
                                </td>
                            {{/if}}

                            {{#each cells}}
                                <td class="{{ class }}">{{> "./_datagrid-cell" }}</td>
                            {{/each}}

                            {{#if row_has_action_slot}}
                                <td class="text-end">
                                    {{#if has_actions}}
                                        <div class="btn-group btn-group-sm flex-wrap justify-content-end"
                                             role="group"
                                             aria-label="{{ t:ui.datagrid.grid_actions }}">
                                            {{#each actions}}
                                                {{#if is_post}}
                                                    <form method="POST"
                                                          action="{{ href }}"
                                                          class="d-inline"
                                                          data-catalyst="form"{{#if has_confirm}}
                                                          data-confirm="{{ confirm }}"{{/if}}>
                                                        {{{ csrf_field }}}
                                                        <button type="submit" class="{{ class }}">
                                                            {{#if has_icon}}<i class="{{ icon }} me-1"></i>{{/if}}
                                                            {{ label }}
                                                        </button>
                                                    </form>
                                                {{else}}
                                                    <button type="button"
                                                            class="{{ class }}"
                                                            data-catalyst-href="{{ href }}">
                                                        {{#if has_icon}}<i class="{{ icon }} me-1"></i>{{/if}}
                                                        {{ label }}
                                                    </button>
                                                {{/if}}
                                            {{/each}}
                                        </div>
                                    {{else}}
                                        <span class="text-muted">—</span>
                                    {{/if}}
                                </td>
                            {{/if}}
                        </tr>
                    {{/each}}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-body py-0">
            <div class="border-top py-2">
                {{> "./_datagrid-toolbar" }}
            </div>
        </div>
    {{/if}}
</section>
