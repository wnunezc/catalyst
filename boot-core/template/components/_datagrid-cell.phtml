{{#if is_stack}}
    <div class="{{ primary_class }}" data-grid-stack-line="primary">
        {{#if primary_truncated}}
            <div class="datagrid-cell-copy-layout d-flex align-items-center gap-1">
                <span class="datagrid-cell-text {{ primary_text_width_class }}"{{#if primary_tooltip}}
                      data-bs-toggle="tooltip"
                      tabindex="0"
                      title="{{ primary_full_text }}"{{/if}}>
                    {{#if primary_is_code}}<code>{{ primary_display_text }}</code>{{else}}{{ primary_display_text }}{{/if}}
                </span>
                {{#if primary_copyable}}
                    <button type="button"
                            class="btn btn-link btn-sm p-0 flex-shrink-0"
                            data-grid-copy
                            data-grid-copy-value="{{ primary_full_text }}"
                            data-grid-copy-label="{{ copy_label }}"
                            data-grid-copied-label="{{ copied_label }}"
                            aria-label="{{ copy_label }}"
                            title="{{ copy_label }}">
                        <i class="ti ti-copy" aria-hidden="true"></i>
                    </button>
                {{/if}}
            </div>
        {{else}}
            {{#if primary_is_code}}<code>{{ primary }}</code>{{else}}{{ primary }}{{/if}}
        {{/if}}
    </div>
    {{#if has_secondary}}
        <div class="{{ secondary_class }}" data-grid-stack-line="secondary">
            {{#if secondary_truncated}}
                <div class="datagrid-cell-copy-layout d-flex align-items-center gap-1">
                    <span class="datagrid-cell-text {{ secondary_text_width_class }}"{{#if secondary_tooltip}}
                          data-bs-toggle="tooltip"
                          tabindex="0"
                          title="{{ secondary_full_text }}"{{/if}}>
                        {{#if secondary_is_code}}<code>{{ secondary_display_text }}</code>{{else}}{{ secondary_display_text }}{{/if}}
                    </span>
                    {{#if secondary_copyable}}
                        <button type="button"
                                class="btn btn-link btn-sm p-0 flex-shrink-0"
                                data-grid-copy
                                data-grid-copy-value="{{ secondary_full_text }}"
                                data-grid-copy-label="{{ copy_label }}"
                                data-grid-copied-label="{{ copied_label }}"
                                aria-label="{{ copy_label }}"
                                title="{{ copy_label }}">
                            <i class="ti ti-copy" aria-hidden="true"></i>
                        </button>
                    {{/if}}
                </div>
            {{else}}
                {{#if secondary_is_code}}<code>{{ secondary }}</code>{{else}}{{ secondary }}{{/if}}
            {{/if}}
        </div>
    {{/if}}
{{else}}
    {{#if has_badges}}
        <div class="d-flex flex-wrap gap-1">
            {{#each badges}}
                <span class="badge {{ class }}">{{ label }}</span>
            {{/each}}
        </div>
    {{else}}
        {{#if has_truncated_text}}
            <div class="datagrid-cell-copy-layout d-flex align-items-center gap-1">
                <span class="datagrid-cell-text {{ text_width_class }}"{{#if tooltip}}
                      data-bs-toggle="tooltip"
                      tabindex="0"
                      title="{{ full_text }}"{{/if}}>
                    {{#if is_code}}<code class="{{ code_class }}">{{ display_text }}</code>{{else}}{{ display_text }}{{/if}}
                </span>
                {{#if copyable}}
                    <button type="button"
                            class="btn btn-link btn-sm p-0 flex-shrink-0"
                            data-grid-copy
                            data-grid-copy-value="{{ full_text }}"
                            data-grid-copy-label="{{ copy_label }}"
                            data-grid-copied-label="{{ copied_label }}"
                            aria-label="{{ copy_label }}"
                            title="{{ copy_label }}">
                        <i class="ti ti-copy" aria-hidden="true"></i>
                    </button>
                {{/if}}
            </div>
        {{else}}
            {{#if is_code}}
                <code class="{{ code_class }}">{{ code_text }}</code>
            {{else}}
                {{ text }}
            {{/if}}
        {{/if}}
    {{/if}}
{{/if}}
