{{#if claim_banner.visible}}
<div
    class="alert {{ claim_banner.alert_class }} d-flex flex-column gap-1 mb-3"
    role="alert"
    data-record-presence
    data-tenant-id="{{ claim_banner.tenant_id }}"
    data-resource-key="{{ claim_banner.resource_key }}"
    data-record-id="{{ claim_banner.record_id }}"
    data-is-owner="{{ claim_banner.is_owner_flag }}"
    data-heartbeat-url="{{ claim_banner.heartbeat_url }}"
>
    <div class="fw-semibold" data-presence-headline>{{ claim_banner.headline }}</div>
    <div data-presence-detail>{{ claim_banner.detail }}</div>
    <div class="small">
        {{#if claim_banner.claimed_at}}
        <span data-presence-claimed-at>{{ t:ui.record_claim.claimed_at }} {{ claim_banner.claimed_at }}</span>
        {{/if}}
        {{#if claim_banner.expires_at}}
        <span data-presence-expires-at class="{{ claim_banner.expires_class }}">{{ t:ui.record_claim.expires_at }} {{ claim_banner.expires_at }}</span>
        {{/if}}
        {{#if claim_banner.released_at}}
        <span data-presence-released-at class="{{ claim_banner.released_class }}">{{ t:ui.record_claim.released_at }} {{ claim_banner.released_at }}</span>
        {{/if}}
    </div>
</div>
{{/if}}
