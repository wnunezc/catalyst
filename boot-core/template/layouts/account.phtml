<!DOCTYPE html>
<html lang="{{ lang }}"
      dir="ltr"
      data-bs-theme="light"
      data-skin="default"
      data-layout-width="fluid"
      data-layout-position="fixed"
      data-menu-color="dark"
      data-sidenav-size="default"
      data-topbar-color="gray">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ document_title }}</title>
    {{{ csrf_meta_tag }}}

    {{#each meta_tags}}
    <meta name="{{ name }}" content="{{ content }}">
    {{/each}}

    <link rel="shortcut icon" href="/assets/vendor/inspinia/images/favicon.ico">
    <script type="application/json" id="account-appearance-json" nonce="{{ csp_nonce }}">{{{ platform_appearance_json }}}</script>
    <script src="/assets/js/catalyst/account-theme-bootstrap.js?v=20260601-account-shell-2" nonce="{{ csp_nonce }}"></script>
    <link href="/assets/vendor/inspinia/css/vendors.min.css" rel="stylesheet" type="text/css">
    <link id="app-style" href="/assets/vendor/inspinia/css/app.min.css" rel="stylesheet" type="text/css">
    <link href="/assets/css/catalyst/red-cross-theme.css?v=20260601-account-shell-2" rel="stylesheet" type="text/css">
    <link href="/assets/css/catalyst/response-skins.css?v=20260601-account-shell-2" rel="stylesheet" type="text/css">
    <link href="/assets/css/catalyst/inspinia-runtime-compat.css?v=20260601-account-shell-2" rel="stylesheet" type="text/css">
    <link href="/assets/css/catalyst/status-bar.css" rel="stylesheet" type="text/css">
    <link href="/assets/css/catalyst/account-shell.css?v=20260601-account-shell-3" rel="stylesheet" type="text/css">

    {{#each style_links}}
    <link href="{{ href }}" rel="{{ rel }}"{{#if has_media}} media="{{ media }}"{{/if}}>
    {{/each}}
</head>
<body class="account-shell-body {{#if is_authenticated}}account-shell-authenticated{{else}}account-shell-guest-body{{/if}}" data-account-shell="true">
{{#if is_authenticated}}
<div class="wrapper account-shell-wrapper">
    {{> "../components/_account-shell-topbar" }}
    {{> "../components/_account-shell-sidenav" }}

    <div class="content-page account-content-page" data-account-content-scroll="true">
        <div class="container-fluid">
            {{#if has_breadcrumbs}}
            <nav class="account-breadcrumb" aria-label="{{ t:account.shell.breadcrumb }}">
                <ol>
                    {{#each breadcrumb_items}}
                    <li class="{{#if is_active}}active{{/if}}">
                        {{#if is_active}}
                        <span>{{ label }}</span>
                        {{else}}
                        <a href="{{ href }}">{{ label }}</a>
                        {{/if}}
                    </li>
                    {{/each}}
                </ol>
            </nav>
            {{/if}}
            {{{ content }}}
        </div>
    </div>
</div>
{{else}}
<div class="account-guest-shell">
    {{{ content }}}
</div>
{{/if}}

{{> "../components/_status-bar" }}
<script src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/assets/js/catalyst/modules/ui-actions.js"></script>
<script src="/assets/js/catalyst/modules/theme-toggle.js"></script>
<script src="/assets/js/catalyst/modules/flash-client.js" type="module"></script>
{{#each script_links}}
<script src="{{ src }}"{{#if has_type}} type="{{ type }}"{{/if}}{{#if defer}} defer{{/if}}{{#if async}} async{{/if}}{{#if has_nonce}} nonce="{{ nonce }}"{{/if}}></script>
{{/each}}
</body>
</html>
