<!DOCTYPE html>
<html lang="{{ lang }}"
      dir="{{ html_dir }}"
      data-bs-theme="{{ html_theme }}"
      data-skin="{{ html_skin }}"
      data-layout-width="{{ html_layout_width }}"
      data-layout-position="{{ html_layout_position }}"
      data-menu-color="{{ html_sidenav_color }}"
      data-sidenav-size="{{ html_sidenav_size }}"
      data-topbar-color="{{ html_topbar_color }}"
      data-catalyst-auth-surface="true">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ document_title }}</title>

    {{#each meta_tags}}
    <meta name="{{ name }}" content="{{ content }}">
    {{/each}}

    {{> "../components/_head-assets" }}
    <link href="/assets/css/catalyst/auth.css?v={{ auth_asset_version }}" rel="stylesheet">

    {{#each style_links}}
    <link href="{{ href }}" rel="{{ rel }}"{{#if has_media}} media="{{ media }}"{{/if}}>
    {{/each}}
</head>
<body class="catalyst-auth-body">
    {{> "../components/_flash-messages" }}

    <div class="auth-layout-shell">
        <div class="auth-layout-shell__content">
            <aside class="auth-brand-panel" aria-label="{{ brand_name }}">
                <div class="auth-brand-panel__header">
                    <span class="auth-brand-panel__mark">
                        {{#if has_brand_logo}}
                        <span class="catalyst-brand-logo-stack">
                            <img src="{{ brand_logo_light_url }}" alt="{{ brand_name }}" class="catalyst-brand-logo catalyst-brand-logo--light">
                            <img src="{{ brand_logo_dark_url }}" alt="{{ brand_name }}" class="catalyst-brand-logo catalyst-brand-logo--dark">
                        </span>
                        {{else}}
                        <span class="auth-brand-panel__monogram">C</span>
                        {{/if}}
                    </span>
                    <div class="auth-brand-panel__copy">
                        <div class="auth-brand-panel__eyebrow">Administration console</div>
                        <div class="auth-brand-panel__name">{{ brand_name }}</div>
                        {{#if has_brand_tagline}}
                        <div class="auth-brand-panel__tagline">{{ brand_tagline }}</div>
                        {{/if}}
                    </div>
                </div>

                <div class="auth-brand-panel__visual">
                    <div class="auth-brand-panel__visual-card">
                        <span class="auth-brand-panel__visual-kicker">{{ auth_surface_title }}</span>
                        <strong class="auth-brand-panel__visual-title">{{ auth_surface_subtitle }}</strong>
                        <span class="auth-brand-panel__visual-caption">{{ auth_surface_note }}</span>
                    </div>
                </div>

                <dl class="auth-brand-panel__facts">
                    <div>
                        <dt>{{ auth_fact_session_label }}</dt>
                        <dd>{{ auth_fact_session_value }}</dd>
                    </div>
                    <div>
                        <dt>{{ auth_fact_access_label }}</dt>
                        <dd>{{ auth_fact_access_value }}</dd>
                    </div>
                    <div>
                        <dt>{{ auth_fact_runtime_label }}</dt>
                        <dd>{{ auth_fact_runtime_value }}</dd>
                    </div>
                </dl>
            </aside>

            <main class="auth-layout-shell__form">
                {{{ content }}}
            </main>
        </div>
    </div>

    {{> "../components/_toaster-container" }}
    {{> "../components/_modal-container" }}
    {{> "../components/_status-bar" }}
    {{> "../components/_body-scripts" }}
    {{> "../components/_catalyst-init" }}

    {{#each script_links}}
    <script src="{{ src }}"{{#if has_type}} type="{{ type }}"{{/if}}{{#if defer}} defer{{/if}}{{#if async}} async{{/if}}{{#if has_nonce}} nonce="{{ nonce }}"{{/if}}></script>
    {{/each}}
</body>
</html>
