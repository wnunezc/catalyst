<?php

declare(strict_types=1);

use Catalyst\Helpers\Security\CspNonce;

$errorArray = is_array($errorArray ?? null) ? $errorArray : [];
$sourceHtml = (string) ($source ?? '');

$translate = static function (string $key, string $default): string {
    if (function_exists('__')) {
        $translated = (string) __($key);
        return $translated !== '' ? $translated : $default;
    }

    return $default;
};

$escape = static fn (mixed $value): string => htmlspecialchars((string) $value, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');

$nonceAttr = '';
if (class_exists(CspNonce::class)) {
    $nonce = CspNonce::get();
    if ($nonce !== '') {
        $nonceAttr = ' nonce="' . $escape($nonce) . '"';
    }
}

$locale = (string) ($_SESSION['app_locale'] ?? 'en');
$errorClass = (string) ($errorArray['class'] ?? 'Error');
$errorDescription = (string) ($errorArray['description'] ?? 'Unexpected application error.');
$errorFile = (string) ($errorArray['file'] ?? '');
$errorLine = (string) ($errorArray['line'] ?? '0');
$errorLevel = (string) ($errorArray['type'] ?? '');
$errorTime = (string) ($errorArray['micro_time'] ?? microtime(true));
$traceMessage = (string) ($errorArray['trace_msg'] ?? '');
?>
<!DOCTYPE html>
<html lang="<?= $escape($locale) ?>">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= $escape($errorClass) ?> | <?= $escape($translate('ui.errors.control_title', 'Error Control Software')) ?></title>
    <style<?= $nonceAttr ?>>
        @import url(/assets/css/firacode/fira_code.css);
        body { font-family: "Roboto", arial, sans-serif; margin: 0; background: #f3f4f6; color: #1f2937; }
        .page-shell { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 32px; box-sizing: border-box; }
        code { font-family: 'Fira Code', monospace; }
        #errorTable { display: table; width: min(1000px, 100%); min-height: 600px; border-collapse: collapse; background: #fff; box-shadow: 0 18px 45px rgba(15, 23, 42, .12); border-radius: 12px; overflow: hidden; }
        td, th { padding: 0.55rem 0.75rem; border: #e5e7eb 1px solid; }
        .col1 { font-weight: 700; width: 16%; text-align: right; background: #f9fafb; }
        .col2 { width: 84%; text-align: left; }
        .head { height: 44px; font-size: 22px; background-color: #d23d24; color: white; }
        .footer { height: 42px; font-size: 18px; background-color: #365D95; color: white; margin: unset; }
        .footer a { color: white; text-decoration: underline; }
        .top { vertical-align: top; }
        .row-1 { height: 34px; font-size: 16px; }
        .container-track { font-family: 'Fira Code', monospace; font-size: 12px; min-height: 30px; height: 150px; max-height: 150px; overflow: auto; white-space: pre-wrap; }
        .container-code { min-height: 30px; height: 275px; max-height: 275px; }
        .container-code code { display: block; height: 100%; font-size: 12px; overflow: auto; }
        .error-source-line { display: inline-block; width: 100%; }
        .error-source-line--highlight { background-color: #ffdddd; font-weight: bold; }
    </style>
</head>
<body>
<div class="page-shell">
    <table id="errorTable">
        <tr><th colspan="2" class="head"><?= $escape($errorClass) ?></th></tr>
        <tr class="row-1"><td class="col1"><?= $escape($translate('ui.errors.description', 'Description:')) ?></td><td class="col2"><?= $escape($errorDescription) ?></td></tr>
        <tr class="row-1"><td class="col1"><?= $escape($translate('ui.errors.file', 'File:')) ?></td><td class="col2"><?= $escape($errorFile) ?></td></tr>
        <tr class="row-1"><td></td><td><b><?= $escape($translate('ui.errors.line', 'Line:')) ?> </b><?= $escape($errorLine) ?> <b><?= $escape($translate('ui.errors.level', 'Level:')) ?> </b><?= $escape($errorLevel) ?> <b><?= $escape($translate('ui.errors.time', 'Time:')) ?> </b><?= $escape($errorTime) ?></td></tr>
        <tr class="row-3"><td class="col1 top"><?= $escape($translate('ui.errors.trace', 'Backtrace Log:')) ?></td><td class="col2"><div class="container-track"><?= $escape($traceMessage) ?></div></td></tr>
        <tr class="row-3"><td class="col1 top"><?= $escape($translate('ui.errors.related_code', 'Related Code View')) ?></td><td class="col2 container-code"><?= $sourceHtml ?></td></tr>
        <tr><th colspan="2" class="footer"><?= $escape($translate('ui.errors.return_hint', 'Please try to Go Back')) ?> <a href="/" id="return"><?= $escape($translate('ui.errors.go_back', 'Go Back')) ?></a></th></tr>
    </table>
</div>
<script<?= $nonceAttr ?>>
    document.addEventListener("DOMContentLoaded", function () {
        var link = document.getElementById("return");
        if (link) {
            link.addEventListener("click", function (event) {
                event.preventDefault();
                document.location.href = "/";
            });
        }
    });
</script>
</body>
</html>
