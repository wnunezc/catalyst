<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - {{ t:ui.route_test.title }}</title>
    <style{{{ style_nonce_attr }}}>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            color: #eee;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            text-align: center;
            padding: 40px;
        }

        h1 {
            font-size: 3.5rem;
            margin-bottom: 0.5rem;
            background: linear-gradient(90deg, #0f3460, #e94560);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .version {
            color: #888;
            font-size: 0.95rem;
            margin-bottom: 2rem;
        }

        .status {
            background: rgba(15, 52, 96, 0.8);
            padding: 25px 50px;
            border-radius: 12px;
            display: inline-block;
            border: 1px solid rgba(74, 222, 128, 0.3);
        }

        .status .icon {
            color: #4ade80;
            font-size: 1.2rem;
            margin-right: 8px;
        }

        .status .text {
            font-size: 1.1rem;
        }

        .note {
            margin-top: 2rem;
            color: #666;
            font-size: 0.85rem;
            font-style: italic;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>{{ title }}</h1>
        <p class="version">{{ t:ui.route_test.version version=version php=phpVersion }}</p>
        <div class="status">
            <span class="icon">✓</span>
            <span class="text">{{ t:ui.route_test.router_ok }}</span>
        </div>
        <p class="note">{{ t:ui.route_test.temporary_page }}</p>
    </div>
</body>
</html>
