# Catalyst Framework - Git Ignore File

#------------------------------------------------------------------------------
# Environment & Configuration
#------------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.backup
boot-core/config/env/.env
boot-core/config/env/.env.*
!boot-core/config/env/.env.example
!boot-core/config/env/.env.ver
/boot-core/config/development/app.json
/boot-core/config/development/db.json
/boot-core/config/development/session.json
!/boot-core/config/development/app.example.json
!/boot-core/config/development/db.example.json
!/boot-core/config/development/session.example.json

#------------------------------------------------------------------------------
# Dependencies
#------------------------------------------------------------------------------
/vendor/
composer.phar

#------------------------------------------------------------------------------
# Logs & Cache
#------------------------------------------------------------------------------
/logs/
/logs/*
!/logs/.gitkeep
/cache/
/cache/*
!/cache/.gitkeep
boot-core/storage/logs/
boot-core/storage/logs/**
boot-core/storage/throttle/
boot-core/storage/throttle/**
boot-core/storage/
boot-core/storage/**
boot-core/storage/*.pid
boot-core/storage/*.stamp

#------------------------------------------------------------------------------
# IDE & Editor Files
#------------------------------------------------------------------------------

# PhpStorm / IntelliJ IDEA
/.idea/
*.iml
*.ipr
*.iws

# VS Code
/.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# NetBeans
/nbproject/

# Eclipse
/.buildpath
/.project
/.settings/

#------------------------------------------------------------------------------
# Operating System Files
#------------------------------------------------------------------------------

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Linux
*~
.directory
.Trash-*

#------------------------------------------------------------------------------
# Temporary Files
#------------------------------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*~
*.bak
*.bak-*
*.old

#------------------------------------------------------------------------------
# Security & Sensitive Data
#------------------------------------------------------------------------------

# DKIM Keys
/bootstrap/dkim/*.key
/bootstrap/dkim/*.pem
boot-core/config/dkim/
boot-core/config/dkim/**
boot-core/config/development/secrets.json

# SSL Certificates
*.pem
*.crt
*.key
*.cert

# Database dumps (solo archivos fuera de database/)
*.sqlite
*.db
*dump*.sql
*backup*.sql
boot-core/database/create-catalyst-db.development.sql

#------------------------------------------------------------------------------
# Build & Compiled Files
#------------------------------------------------------------------------------
*.log
*.cache
*.compiled

#------------------------------------------------------------------------------
# PHP Specific
#------------------------------------------------------------------------------
phpunit.xml
.phpunit.result.cache
/phpunit/
coverage/
.php_cs.cache
.php-cs-fixer.cache

#------------------------------------------------------------------------------
# Node.js (if using frontend build tools)
#------------------------------------------------------------------------------
/node_modules/
npm-debug.log
yarn-error.log
yarn-debug.log
package-lock.json
.npm
.yarn

#------------------------------------------------------------------------------
# Docker
#------------------------------------------------------------------------------
docker-compose.override.yml

#------------------------------------------------------------------------------
# Backup & Archive Files
#------------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.rar
*.7z

#------------------------------------------------------------------------------
# Documentation Build Files
