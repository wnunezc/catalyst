/docs/_build/
/docs/.doctrees/

#------------------------------------------------------------------------------
# Testing
#------------------------------------------------------------------------------
/test/reports/
/test/coverage/

#------------------------------------------------------------------------------
# Project Specific
#------------------------------------------------------------------------------

# Keep empty directories
!.gitkeep

# Temporary development files
/temp/
/tmp/
scratch.php
test.php
debug.php

